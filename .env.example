# =============================================================================
# HolyOS — Environment variables (příklad)
# Zkopíruj do .env a doplň reálné hodnoty.
# =============================================================================

# ─── Databáze ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/holyos"

# ─── Aplikace ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000                  # pro absolutní odkazy v emailech

# ─── Autentizace (JWT) ──────────────────────────────────────────────────────
JWT_SECRET="zmen-tenhle-secret-v-produkci"
JWT_EXPIRY=24h

# ─── Anthropic Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── SMTP (emailové notifikace) ─────────────────────────────────────────────
# Nastav pro odesílání notifikací o nových chat zprávách na email.
# Pokud SMTP_HOST chybí, emaily jsou tiše vypnuté.
#
# Gmail:   host=smtp.gmail.com, port=465, secure=true, vygeneruj "App password"
# Seznam:  host=smtp.seznam.cz, port=465, secure=true
# SendGrid: host=smtp.sendgrid.net, port=587, secure=false, user=apikey, pass=SG.xxx
# Railway: zvaž službu jako Mailgun, SendGrid, Postmark (vnitřní SMTP na Railway není)

SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="HolyOS <noreply@example.com>"

# Pokud chceš emaily v dev prostředí úplně vypnout bez mazání SMTP_HOST:
# EMAIL_DISABLED=true

# ─── Factorify API (volitelné) ──────────────────────────────────────────────
FACTORIFY_BASE_URL=
FACTORIFY_TOKEN=
FACTORIFY_ACCOUNTING_UNIT=
