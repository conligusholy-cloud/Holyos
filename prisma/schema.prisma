// =============================================================================
// HolyOS — Prisma Schema v1.0
// Kompletní datový model pro výrobní systém
// Generováno: 2026-04-13
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector"), uuidOssp(map: "uuid-ossp")]
}

// =============================================================================
// AUTENTIZACE & UŽIVATELÉ
// =============================================================================

model User {
  id             Int      @id @default(autoincrement())
  username       String   @unique @db.VarChar(100)
  display_name   String   @db.VarChar(255)
  password_hash  String   @db.VarChar(255) // bcrypt hash (nahrazuje PBKDF2)
  role           String   @default("user") @db.VarChar(20)
  is_super_admin Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  // Vztahy
  person      Person?     @relation("UserPerson")
  sessions    Session[]
  admin_tasks AdminTask[] @relation("AdminTaskCreator")

  // Messaging (user-to-user chat, oddělený od AI Conversation)
  chat_memberships ChatChannelMember[]
  chat_messages    ChatMessage[]       @relation("ChatMessageSender")
  created_channels ChatChannel[]       @relation("ChatChannelCreator")
  notifications    Notification[]

  // Účetní doklady — vždy vyplněný User, který fakturu vytvořil
  invoices_created Invoice[] @relation("InvoiceCreatorUser")

  // App settings — kdo poslední změnil
  app_settings_updated AppSetting[] @relation("AppSettingUpdater")

  // Schvalování objednávek — kdo schválil (User FK pro audit, Tomáš nemá vždy Person)
  orders_approved_user Order[] @relation("OrderApproverUser")

  @@map("users")
}

model Session {
  id         String   @id @default(uuid())
  user_id    Int
  token      String   @unique @db.VarChar(500)
  expires_at DateTime
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expires_at])
  @@map("sessions")
}

// =============================================================================
// HR — LIDÉ & ORGANIZACE
// =============================================================================

model Person {
  id         Int     @id @default(autoincrement())
  type       String  @default("employee") @db.VarChar(50)
  first_name String  @db.VarChar(255)
  last_name  String  @db.VarChar(255)
  email      String? @db.VarChar(255)
  phone      String? @db.VarChar(20)
  notes      String? @db.Text
  active     Boolean @default(true)

  // Zaměstnanecké údaje
  employee_number String?   @db.VarChar(50)
  hire_date       DateTime? @db.Date
  end_date        DateTime? @db.Date
  contract_type   String?   @db.VarChar(50)
  hourly_rate     Decimal?  @db.Decimal(10, 2)
  monthly_salary  Decimal?  @db.Decimal(10, 2)
  bank_account    String?   @db.VarChar(50)

  // Osobní údaje
  birth_date     DateTime? @db.Date
  birth_number   String?   @db.VarChar(20)
  id_card_number String?   @db.VarChar(20)
  gender         String?   @db.VarChar(10)
  address        String?   @db.VarChar(255)
  city           String?   @db.VarChar(100)
  zip            String?   @db.VarChar(10)

  // Kontakt pro případ nouze
  emergency_name     String? @db.VarChar(255)
  emergency_phone    String? @db.VarChar(20)
  emergency_relation String? @db.VarChar(100)

  // Systémové
  photo_url      String? @db.Text
  chip_number    String? @db.VarChar(50)
  chip_card_id   String? @db.VarChar(50)
  is_super_admin Boolean @default(false)
  username       String? @db.VarChar(100)

  // Oprávnění pro specifické funkce. Zatím jediný flag — může odevzdávat CAD
  // výkresy ze SolidWorksu přes desktop klient HolyOS CAD Bridge.
  can_upload_cad Boolean @default(false)

  // Dovolená
  leave_entitlement_days Int?
  leave_carryover        Int?

  // FK
  department_id Int?
  role_id       Int?
  supervisor_id Int?
  shift_id      Int?
  user_id       Int? @unique
  company_id    Int?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Vztahy
  department   Department? @relation(fields: [department_id], references: [id])
  role         Role?       @relation(fields: [role_id], references: [id])
  company      Company?    @relation("PersonCompany", fields: [company_id], references: [id])
  supervisor   Person?     @relation("PersonSupervisor", fields: [supervisor_id], references: [id])
  subordinates Person[]    @relation("PersonSupervisor")
  shift        Shift?      @relation(fields: [shift_id], references: [id])
  user         User?       @relation("UserPerson", fields: [user_id], references: [id])

  attendance                  Attendance[]
  leave_requests              LeaveRequest[]         @relation("LeaveRequestPerson")
  approved_leaves             LeaveRequest[]         @relation("LeaveRequestApprover")
  overtime_requests           OvertimeRequest[]      @relation("OvertimeRequestPerson")
  approved_overtime           OvertimeRequest[]      @relation("OvertimeRequestApprover")
  documents                   Document[]
  doc_notifications           DocumentNotification[]
  orders_created              Order[]                @relation("OrderCreatedBy")
  orders_approved             Order[]                @relation("OrderApprovedBy")
  inventory_movements         InventoryMovement[]    @relation("MovementCreatedBy")
  managed_warehouses          Warehouse[]            @relation("WarehouseManager")
  inventories_created         Inventory[]            @relation("InventoryCreatedBy")
  inventory_counted           InventoryItem[]        @relation("InventoryCountedBy")
  workstation_assignments     WorkstationWorker[]
  assigned_vehicles           Vehicle[]              @relation("VehicleDriver")
  cad_drawings_created        CadDrawing[]           @relation("CadDrawingCreator")
  cad_change_logs             CadDrawingChangeLog[]  @relation("CadDrawingChangeLogAuthor")
  // SKLAD 2.0
  warehouse_documents_created WarehouseDocument[]    @relation("WarehouseDocumentCreator")
  batches_assigned            Batch[]                @relation("BatchAssignee")
  batch_items_picked          BatchItem[]            @relation("BatchItemPickedBy")
  print_jobs                  PrintJob[]             @relation("PrintJobRequestedBy")
  serials_received            SerialNumber[]         @relation("SerialReceivedBy")
  serials_issued              SerialNumber[]         @relation("SerialIssuedBy")
  lots_received               MaterialLot[]          @relation("MaterialLotReceivedBy")

  // Účetní doklady — faktury, schvalování, platby, pokladna, cost-centers
  invoices_created           Invoice[]             @relation("InvoiceCreator")
  invoices_approved          Invoice[]             @relation("InvoiceApprover")
  invoice_approval_steps     InvoiceApprovalStep[] @relation("InvoiceApprovalStepApprover")
  invoice_items_as_person    InvoiceItem[]         @relation("InvoiceItemPerson")
  cost_centers_as_target     CostCenter[]          @relation("CostCenterPerson")
  cash_registers_responsible CashRegister[]        @relation("CashRegisterResponsible")
  cash_movements_created     CashMovement[]        @relation("CashMovementCreator")
  payment_batches_created    PaymentBatch[]        @relation("PaymentBatchCreator")

  @@index([department_id])
  @@index([role_id])
  @@index([company_id])
  @@index([active])
  @@index([chip_number])
  @@index([chip_card_id])
  @@map("people")
}

model Department {
  id        Int     @id @default(autoincrement())
  name      String  @db.VarChar(255)
  color     String? @db.VarChar(7)
  parent_id Int?

  created_at DateTime @default(now())

  // Vztahy
  parent       Department?  @relation("DepartmentHierarchy", fields: [parent_id], references: [id])
  children     Department[] @relation("DepartmentHierarchy")
  people       Person[]
  roles        Role[]
  cost_centers CostCenter[] @relation("CostCenterDepartment")

  @@map("departments")
}

model Role {
  id             Int     @id @default(autoincrement())
  name           String  @db.VarChar(255)
  description    String? @db.Text
  department_id  Int?
  parent_role_id Int?
  company_id     Int?

  created_at DateTime @default(now())

  // Vztahy
  department  Department?  @relation(fields: [department_id], references: [id])
  parent_role Role?        @relation("RoleHierarchy", fields: [parent_role_id], references: [id])
  child_roles Role[]       @relation("RoleHierarchy")
  company     Company?     @relation("RoleCompany", fields: [company_id], references: [id])
  people      Person[]
  permissions Permission[]

  @@index([company_id])
  @@map("roles")
}

model Shift {
  id            Int     @id @default(autoincrement())
  name          String  @db.VarChar(255)
  type          String  @default("fixed") @db.VarChar(20) // fixed, flexible
  start_time    String? @db.VarChar(5) // HH:MM
  end_time      String? @db.VarChar(5) // HH:MM
  hours_fund    Decimal @default(8.0) @db.Decimal(5, 2)
  break_minutes Int     @default(30)

  created_at DateTime @default(now())

  people Person[]

  @@map("shifts")
}

// =============================================================================
// HR — DOCHÁZKA & DOVOLENÁ
// =============================================================================

model Attendance {
  id                 Int      @id @default(autoincrement())
  person_id          Int
  date               DateTime @db.Date
  clock_in           String?  @db.VarChar(5) // HH:MM
  clock_out          String?  @db.VarChar(5)
  break_minutes      Int      @default(30)
  type               String   @default("work") @db.VarChar(50)
  note               String?  @db.Text
  adjusted_clock_in  String?  @db.VarChar(5)
  adjusted_clock_out String?  @db.VarChar(5)
  adjusted_break     Int?

  created_at DateTime @default(now())

  person Person @relation(fields: [person_id], references: [id])

  @@index([person_id, date])
  @@index([date])
  @@map("attendance")
}

model AbsenceType {
  id    Int     @id @default(autoincrement())
  name  String  @db.VarChar(255)
  code  String  @unique @db.VarChar(50)
  color String? @db.VarChar(7)
  paid  Boolean @default(false)

  @@map("absence_types")
}

model LeaveRequest {
  id          Int      @id @default(autoincrement())
  person_id   Int
  type        String   @db.VarChar(50) // vacation, sick, etc.
  date_from   DateTime @db.Date
  date_to     DateTime @db.Date
  note        String?  @db.Text
  status      String   @default("pending") @db.VarChar(20)
  approved_by Int?

  created_at DateTime @default(now())

  person   Person  @relation("LeaveRequestPerson", fields: [person_id], references: [id])
  approver Person? @relation("LeaveRequestApprover", fields: [approved_by], references: [id])

  @@index([person_id])
  @@index([status])
  @@map("leave_requests")
}

model CompanyLeave {
  id                  Int      @id @default(autoincrement())
  name                String   @db.VarChar(255)
  date_from           DateTime @db.Date
  date_to             DateTime @db.Date
  excluded_person_ids Json? // int[]

  created_at DateTime @default(now())

  @@map("company_leave")
}

model Permission {
  id           Int    @id @default(autoincrement())
  role_id      Int
  module_id    String @db.VarChar(100)
  access_level String @default("none") @db.VarChar(20) // none, read, write

  role Role @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@unique([role_id, module_id])
  @@map("permissions")
}

// =============================================================================
// HR — NASTAVENÍ
// =============================================================================

model LeaveSettings {
  id                       Int     @id @default(1)
  default_entitlement_days Int     @default(20)
  year                     Int     @default(2026)
  carryover_allowed        Boolean @default(true)
  carryover_max_days       Int     @default(5)

  @@map("leave_settings")
}

model OvertimeSettings {
  id                      Int     @id @default(1)
  yearly_limit_hours      Int     @default(150)
  yearly_absolute_max     Int     @default(416)
  alert_threshold_percent Int     @default(80)
  compensation            String  @default("surcharge") @db.VarChar(20) // surcharge, timeoff
  surcharge_percent       Int     @default(25)
  allow_monthly_transfer  Boolean @default(true)

  @@map("overtime_settings")
}

model OvertimeRequest {
  id          Int     @id @default(autoincrement())
  person_id   Int
  hours       Decimal @db.Decimal(5, 2) // kladné = převod přesčasů na volno, záporné = odpracování dluhu
  type        String  @db.VarChar(50) // transfer_to_leave (přesčas→volno), transfer_to_pay (přesčas→peníze), debt_work (odpracování záporných)
  note        String? @db.Text
  status      String  @default("pending") @db.VarChar(20) // pending, approved, rejected
  approved_by Int?
  month       String  @db.VarChar(7) // YYYY-MM — měsíc ke kterému se přesčas vztahuje

  created_at DateTime @default(now())

  person   Person  @relation("OvertimeRequestPerson", fields: [person_id], references: [id])
  approver Person? @relation("OvertimeRequestApprover", fields: [approved_by], references: [id])

  @@index([person_id])
  @@index([status])
  @@map("overtime_requests")
}

// =============================================================================
// DOKUMENTY
// =============================================================================

model Document {
  id         Int       @id @default(autoincrement())
  person_id  Int
  title      String    @db.VarChar(255)
  type       String    @db.VarChar(50) // contract, certificate, medical
  category   String?   @db.VarChar(50)
  file_data  String?   @db.Text // base64
  file_name  String?   @db.VarChar(255)
  file_type  String?   @db.VarChar(50)
  file_size  Int?
  valid_from DateTime? @db.Date
  valid_to   DateTime? @db.Date
  status     String    @default("active") @db.VarChar(20)
  tags       Json? // string[]
  note       String?   @db.Text

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  person        Person                 @relation(fields: [person_id], references: [id])
  notifications DocumentNotification[]

  @@index([person_id])
  @@index([valid_to])
  @@map("documents")
}

model DocumentTemplate {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(255)
  category    String? @db.VarChar(50)
  content     String  @db.Text // HTML s {{placeholder}}
  variables   Json? // string[]
  description String? @db.Text

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("document_templates")
}

model DocumentNotification {
  id                  Int       @id @default(autoincrement())
  document_id         Int
  person_id           Int
  type                String    @db.VarChar(20) // expiring, expired, custom
  trigger_days_before Int?
  message             String?   @db.VarChar(255)
  sent_at             DateTime?
  dismissed           Boolean   @default(false)

  created_at DateTime @default(now())

  document Document @relation(fields: [document_id], references: [id], onDelete: Cascade)
  person   Person   @relation(fields: [person_id], references: [id])

  @@map("document_notifications")
}

// =============================================================================
// SKLAD — FIRMY & OBJEDNÁVKY
// =============================================================================

model Company {
  id                 Int     @id @default(autoincrement())
  name               String  @db.VarChar(255)
  ico                String? @db.VarChar(20)
  dic                String? @db.VarChar(20)
  // Adresa sídla (fakturační)
  address            String? @db.VarChar(255)
  city               String? @db.VarChar(100)
  zip                String? @db.VarChar(10)
  country            String  @default("CZ") @db.VarChar(2)
  // Adresa provozovny (kam se fyzicky jezdí na servis / odkud probíhá dodání)
  branch_address     String? @db.VarChar(255)
  branch_city        String? @db.VarChar(100)
  branch_zip         String? @db.VarChar(10)
  type               String  @db.VarChar(50) // supplier, customer, cooperation, both, service_provider
  contact_person     String? @db.VarChar(255)
  email              String? @db.VarChar(255)
  phone              String? @db.VarChar(20)
  web                String? @db.VarChar(255)
  bank_account       String? @db.VarChar(50)
  // Whitelist potvrzených bankovních účtů (anti-podvod). JSON pole záznamů
  // { account, iban?, verified_by_user_id, verified_at, source, note? }.
  // Při schválení faktury / klik "Potvrdit účet" se sem účet přidá.
  // Faktura s neznámým účtem od známé firmy dostane v UI red flag.
  verified_bank_accounts Json @default("[]")
  payment_terms_days Int     @default(14)
  notes              String? @db.Text
  active             Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  orders               Order[]
  supplied_materials   Material[]          @relation("MaterialSupplier")
  preferred_for_rules  StockRule[]         @relation("StockRuleSupplier")
  people               Person[]            @relation("PersonCompany")
  roles                Role[]              @relation("RoleCompany")
  // Fleet — servisní firmy a pneuservisy
  vehicle_services     VehicleService[]    @relation("VehicleServiceCompany")
  vehicle_tire_changes VehicleTireChange[] @relation("VehicleTireCompany")
  // Provozovny (více poboček pod jednou firmou v adresáři)
  branches             CompanyBranch[]     @relation("CompanyBranches")
  // SKLAD 2.0 — dodavatel/odběratel na skladovém dokumentu (DL, výdejka)
  warehouse_documents  WarehouseDocument[] @relation("WarehouseDocumentPartner")
  supplied_lots        MaterialLot[]       @relation("MaterialLotSupplier")
  // Účetní doklady — faktury přijaté (AP) i vydané (AR)
  invoices             Invoice[]           @relation("InvoiceCompany")

  @@index([ico])
  @@index([type])
  @@map("companies")
}

model Order {
  id                Int       @id @default(autoincrement())
  order_number      String    @unique @db.VarChar(50)
  type              String    @db.VarChar(20) // purchase, sales, cooperation
  company_id        Int
  status            String    @default("new") @db.VarChar(20)
  items_count       Int       @default(0)
  total_amount      Decimal   @default(0) @db.Decimal(12, 2)
  currency          String    @default("CZK") @db.VarChar(3)
  note              String?   @db.Text
  created_by        Int?
  approved_by       Int? // legacy Person FK — zachováno; nově preferujeme approved_by_user_id
  expected_delivery DateTime? @db.Date
  delivered_at      DateTime? @db.Date
  share_token       String?   @unique @db.VarChar(64)

  // Schvalovací workflow (manuální vs MRP autogen) — Fáze "Schvalování objednávek"
  // approval_status: pending | submitted | approved | rejected | auto_approved
  //   pending       = draft, ještě neodesláno řediteli
  //   submitted     = posláno ke schválení (čeká na ředitele)
  //   approved      = ředitel schválil (přechod přes /api/wh/orders/:id/approve)
  //   rejected      = ředitel zamítl s poznámkou — vrácení do pending pro úpravu
  //   auto_approved = MRP/stockrule autogenerovaná Order, neprojde lidským schválením
  approval_status            String    @default("pending") @db.VarChar(20)
  approved_by_user_id        Int? // User FK pro audit (Tomášův User nemá vždy Person)
  approved_at                DateTime?
  approval_note              String?   @db.Text // důvod zamítnutí, případně poznámka schvalovatele
  submitted_for_approval_at  DateTime?
  // source: kdo Order vytvořil — 'manual' (z UI), 'mrp_autogen' (auto z stockrule),
  //   'import' (Factorify migrace). manual → vyžaduje schválení; ostatní → auto_approved.
  source                     String    @default("manual") @db.VarChar(20)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company       Company     @relation(fields: [company_id], references: [id])
  creator       Person?     @relation("OrderCreatedBy", fields: [created_by], references: [id])
  approver      Person?     @relation("OrderApprovedBy", fields: [approved_by], references: [id])
  approver_user User?       @relation("OrderApproverUser", fields: [approved_by_user_id], references: [id])
  items         OrderItem[]
  invoices      Invoice[]   @relation("InvoiceOrder")

  @@index([type])
  @@index([status])
  @@index([company_id])
  @@index([approval_status])
  @@map("orders")
}

model OrderItem {
  id                 Int       @id @default(autoincrement())
  order_id           Int
  material_id        Int?
  product_id         Int? // vazba na Product (výrobek)
  name               String    @db.VarChar(255)
  quantity           Decimal   @db.Decimal(10, 2)
  unit               String    @default("ks") @db.VarChar(20)
  unit_price         Decimal   @default(0) @db.Decimal(10, 2)
  total_price        Decimal   @default(0) @db.Decimal(12, 2)
  expected_delivery  DateTime? @db.Date
  delivered_quantity Decimal   @default(0) @db.Decimal(10, 2)
  status             String    @default("pending") @db.VarChar(20)
  note               String?   @db.Text
  serial_number      String?   @db.VarChar(100) // Výrobní číslo kiosku (přidělené ručně na úrovni položky)

  order            Order             @relation(fields: [order_id], references: [id], onDelete: Cascade)
  material         Material?         @relation(fields: [material_id], references: [id])
  product          Product?          @relation(fields: [product_id], references: [id], onDelete: SetNull)
  configs          OrderItemConfig[] // vybraná konfigurace pro tento výrobek
  slot_assignments SlotAssignment[] // přiřazení do výrobních slotů (pro zobrazení výrobního čísla v náhledu)
  invoice_items    InvoiceItem[]     @relation("InvoiceItemOrderItem")

  @@index([order_id])
  @@index([product_id])
  @@index([serial_number])
  @@map("order_items")
}

// =============================================================================
// SKLAD — SKLADY & MATERIÁLY
// =============================================================================

model Warehouse {
  id         Int     @id @default(autoincrement())
  name       String  @db.VarChar(255)
  code       String? @db.VarChar(50)
  address    String? @db.VarChar(255)
  type       String  @default("main") @db.VarChar(50)
  manager_id Int?
  active     Boolean @default(true)

  created_at DateTime @default(now())

  manager             Person?             @relation("WarehouseManager", fields: [manager_id], references: [id])
  locations           WarehouseLocation[]
  movements           InventoryMovement[]
  stock_rules         StockRule[]
  inventories         Inventory[]
  workstations_input  Workstation[]       @relation("WorkstationInputWarehouse")
  workstations_output Workstation[]       @relation("WorkstationOutputWarehouse")

  @@map("warehouses")
}

model WarehouseLocation {
  id                   Int      @id @default(autoincrement())
  warehouse_id         Int
  section              String?  @db.VarChar(50)
  rack                 String?  @db.VarChar(50)
  position             String?  @db.VarChar(50)
  label                String   @unique @db.VarChar(255)
  barcode              String?  @unique @db.VarChar(100) // QR kód na etiketě lokace
  type                 String   @default("position") @db.VarChar(30) // warehouse, aisle, rack, position, workstation_in, workstation_out
  capacity             Decimal? @db.Decimal(10, 2)
  locked_for_inventory Boolean  @default(false) // SKLAD 2.0 — zámek po dobu probíhající inventury
  notes                String?  @db.Text

  warehouse           Warehouse           @relation(fields: [warehouse_id], references: [id])
  movements           InventoryMovement[]
  inventory_items     InventoryItem[]
  workstations_input  Workstation[]       @relation("WorkstationInputLocation")
  workstations_output Workstation[]       @relation("WorkstationOutputLocation")
  stock               Stock[] // SKLAD 2.0 — zásoby na lokaci
  outgoing_transfers  InventoryMovement[] @relation("MovementFromLocation") // přesuny "z této lokace"
  incoming_transfers  InventoryMovement[] @relation("MovementToLocation") // přesuny "do této lokace"
  printers            Printer[] // tiskárny přiřazené k této lokaci
  batch_items_from    BatchItem[] // pickovací položky zdrojové lokace
  serial_numbers      SerialNumber[] // sériová čísla aktuálně umístěná na lokaci

  @@index([warehouse_id])
  @@index([type])
  @@map("warehouse_locations")
}

model Material {
  id          Int     @id @default(autoincrement())
  code        String  @unique @db.VarChar(50)
  name        String  @db.VarChar(255)
  external_id String? @db.VarChar(100)
  status      String  @default("active") @db.VarChar(20)
  type        String  @default("material") @db.VarChar(50)
  unit        String  @default("ks") @db.VarChar(20)
  barcode     String? @unique @db.VarChar(100) // QR kód na etiketě — unikátní pro lookup ze čtečky
  sector      String? @db.VarChar(20) // vyroba, stavba, servis, eshop, pradelna

  // Ceny & zásoby
  unit_price         Decimal? @db.Decimal(10, 2)
  weighted_avg_price Decimal? @db.Decimal(10, 2)
  current_stock      Decimal  @default(0) @db.Decimal(10, 2)
  min_stock          Decimal? @db.Decimal(10, 2)
  max_stock          Decimal? @db.Decimal(10, 2)
  min_stock_type     String?  @db.VarChar(20)
  max_stock_type     String?  @db.VarChar(20)

  // Dodavatel & dodací lhůta
  supplier_id    Int?
  lead_time_days Decimal? @db.Decimal(5, 2)

  // Dávky & objednávky
  batch_size_min          Decimal? @db.Decimal(10, 2)
  batch_size_max          Decimal? @db.Decimal(10, 2)
  batch_size_default      Decimal? @db.Decimal(10, 2)
  processed_in_multiples  Decimal? @db.Decimal(10, 2)
  reorder_quantity        Decimal? @db.Decimal(10, 2)
  expedition_reserve_days Decimal? @db.Decimal(5, 2)
  delivery_tolerance_pct  Decimal? @db.Decimal(5, 2)
  plan_orders             Boolean  @default(false)

  // Klasifikace
  classification String? @db.VarChar(50)
  family         String? @db.VarChar(100)
  material_group String? @db.VarChar(100) // "group" je reserved
  norm           String? @db.VarChar(100)

  // Fyzické vlastnosti
  weight          Decimal? @db.Decimal(10, 3)
  dimension       String?  @db.VarChar(255)
  color           String?  @db.VarChar(7)
  secondary_color String?  @db.VarChar(7)

  // Výroba / design
  material_ref     String? @db.VarChar(100)
  semi_product_ref String? @db.VarChar(100)
  route            String? @db.VarChar(100)
  revision_number  String? @db.VarChar(50)
  order_number     String? @db.VarChar(100)
  position         String? @db.VarChar(100)
  drawn_by         String? @db.VarChar(100)
  toolbox_name     String? @db.VarChar(255)
  solid_name       String? @db.VarChar(100)

  // Skladové příznaky
  non_stock                     Boolean @default(false)
  distinguish_batches           Boolean @default(false)
  interchangeable_batches       Boolean @default(false)
  no_availability_check         Boolean @default(false)
  check_availability_stage      Boolean @default(false)
  check_availability_expedition Boolean @default(false)
  mandatory_scan                Boolean @default(false)
  save_sn_first_scan            Boolean @default(false)
  temp_barcode                  Boolean @default(false)
  auto_complete_after_bom_scan  Boolean @default(false)
  exact_consumption             Boolean @default(false)
  ignore                        Boolean @default(false)
  ignore_forecast_eval          Boolean @default(false)
  split_receipt_by_sales_items  Boolean @default(false)

  // Expirace
  expirable                     Boolean  @default(false)
  shelf_life                    String?  @db.VarChar(20)
  shelf_life_unit               String?  @db.VarChar(20)
  max_acceptable_shelf_life_pct Decimal? @db.Decimal(5, 2)
  allow_rotation                Boolean  @default(false)

  // Plánování
  priority                     Int?
  release_before_dispatch_days Decimal? @db.Decimal(5, 2)
  forecast_pct                 Decimal? @db.Decimal(5, 2)
  sort_weight                  Decimal? @db.Decimal(10, 2)
  daily_target                 Decimal? @db.Decimal(10, 2)

  // Ostatní
  stock_substitution     String?   @db.VarChar(50)
  internal_status        String?   @db.VarChar(50)
  valid_from             DateTime? @db.Date
  valid_to               DateTime? @db.Date
  customers              String?   @db.Text
  internal_value         String?   @db.VarChar(100)
  active_flag            String?   @db.VarChar(20)
  export_state           String?   @db.VarChar(50)
  accounting_unit        String?   @db.VarChar(50)
  goods_template         String?   @db.VarChar(100)
  sn_mask                String?   @db.VarChar(50)
  uses_service_eshop     Boolean   @default(false)
  alt_unit               String?   @db.VarChar(20)
  alt_unit_coeff         Decimal?  @db.Decimal(10, 2)
  similar_goods          String?   @db.VarChar(255)
  alt_goods              String?   @db.VarChar(255)
  alt_goods_forecast     String?   @db.VarChar(255)
  target_warehouse       String?   @db.VarChar(50)
  wait_after_stock_hours Decimal?  @db.Decimal(5, 2)
  keywords               String?   @db.Text
  photo_url              String?   @db.Text
  description            String?   @db.Text
  production_note        String?   @db.Text
  factorify_id           String?   @db.VarChar(100)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Vztahy
  supplier                Company?               @relation("MaterialSupplier", fields: [supplier_id], references: [id])
  movements               InventoryMovement[]
  order_items             OrderItem[]
  stock_rules             StockRule[]
  inventory_items         InventoryItem[]
  operation_materials     OperationMaterial[]
  config_option_materials ConfigOptionMaterial[] // konfigurace, které tento materiál používají
  cad_components          CadComponent[] // komponenty v CAD kusovníkách namapované na tento materiál
  stock                   Stock[] // SKLAD 2.0 — zásoby po lokacích (rychlý lookup)
  batch_items             BatchItem[] // SKLAD 2.0 — položky v pickovacích dávkách
  serial_numbers          SerialNumber[] // SKLAD 2.0 — sériová čísla per kus (pokud save_sn_first_scan)
  lots                    MaterialLot[] // SKLAD 2.0 — šarže (pokud expirable / distinguish_batches)
  invoice_items           InvoiceItem[]          @relation("InvoiceItemMaterial") // řádky faktur odkazující na tento materiál

  @@index([code])
  @@index([supplier_id])
  @@index([factorify_id])
  @@index([sector])
  @@map("materials")
}

model InventoryMovement {
  id               Int      @id @default(autoincrement())
  material_id      Int
  warehouse_id     Int
  location_id      Int? // pro jednoduchý příjem/výdej (backward-compat)
  from_location_id Int? // SKLAD 2.0 — zdrojová lokace pro transfer/pick
  to_location_id   Int? // SKLAD 2.0 — cílová lokace pro transfer/příjem
  type             String   @db.VarChar(20) // receipt, issue, transfer, adjustment, pick, inventory_adjust
  quantity         Decimal  @db.Decimal(10, 2)
  unit_price       Decimal? @db.Decimal(10, 2)
  reference_type   String?  @db.VarChar(50) // order, project, inventory, manual, document, batch
  reference_id     Int?
  document_id      Int? // SKLAD 2.0 — zastřešující dokument (DL, výdejka, přesunka, inventurní protokol)
  client_uuid      String?  @unique @db.Uuid // SKLAD 2.0 — offline dedup z PWA čtečky
  device_id        String?  @db.VarChar(100) // SKLAD 2.0 — audit: z jaké čtečky pohyb přišel
  note             String?  @db.Text
  created_by       Int?

  created_at DateTime @default(now())

  material         Material           @relation(fields: [material_id], references: [id])
  warehouse        Warehouse          @relation(fields: [warehouse_id], references: [id])
  location         WarehouseLocation? @relation(fields: [location_id], references: [id])
  from_location    WarehouseLocation? @relation("MovementFromLocation", fields: [from_location_id], references: [id])
  to_location      WarehouseLocation? @relation("MovementToLocation", fields: [to_location_id], references: [id])
  document         WarehouseDocument? @relation(fields: [document_id], references: [id])
  creator          Person?            @relation("MovementCreatedBy", fields: [created_by], references: [id])
  serials_received SerialNumber[]     @relation("SerialReceivedMove") // S/N přijatá tímto pohybem
  serials_issued   SerialNumber[]     @relation("SerialIssuedMove") // S/N vydaná tímto pohybem
  lots_received    MaterialLot[]      @relation("MaterialLotReceivedMove") // šarže přijaté tímto pohybem

  @@index([material_id])
  @@index([warehouse_id])
  @@index([created_at])
  @@index([document_id])
  @@index([from_location_id])
  @@index([to_location_id])
  @@map("inventory_movements")
}

model StockRule {
  id                    Int      @id @default(autoincrement())
  material_id           Int
  warehouse_id          Int?
  min_stock             Decimal? @db.Decimal(10, 2)
  max_stock             Decimal? @db.Decimal(10, 2)
  reorder_quantity      Decimal? @db.Decimal(10, 2)
  auto_order            Boolean  @default(false)
  preferred_supplier_id Int?
  notes                 String?  @db.Text

  material  Material   @relation(fields: [material_id], references: [id])
  warehouse Warehouse? @relation(fields: [warehouse_id], references: [id])
  supplier  Company?   @relation("StockRuleSupplier", fields: [preferred_supplier_id], references: [id])

  @@map("stock_rules")
}

// =============================================================================
// SKLAD — INVENTURY
// =============================================================================

model Inventory {
  id           Int       @id @default(autoincrement())
  warehouse_id Int
  name         String    @db.VarChar(255)
  status       String    @default("draft") @db.VarChar(20)
  started_at   DateTime?
  completed_at DateTime?
  created_by   Int?
  note         String?   @db.Text

  created_at DateTime @default(now())

  warehouse Warehouse       @relation(fields: [warehouse_id], references: [id])
  creator   Person?         @relation("InventoryCreatedBy", fields: [created_by], references: [id])
  items     InventoryItem[]

  @@map("inventories")
}

model InventoryItem {
  id               Int       @id @default(autoincrement())
  inventory_id     Int
  material_id      Int
  location_id      Int?
  expected_qty     Decimal   @db.Decimal(10, 2)
  actual_qty       Decimal?  @db.Decimal(10, 2)
  difference       Decimal?  @db.Decimal(10, 2)
  unit_price       Decimal?  @db.Decimal(10, 2)
  value_difference Decimal?  @db.Decimal(12, 2)
  counted_by       Int?
  counted_at       DateTime?
  note             String?   @db.Text

  inventory Inventory          @relation(fields: [inventory_id], references: [id], onDelete: Cascade)
  material  Material           @relation(fields: [material_id], references: [id])
  location  WarehouseLocation? @relation(fields: [location_id], references: [id])
  counter   Person?            @relation("InventoryCountedBy", fields: [counted_by], references: [id])

  @@index([inventory_id])
  @@map("inventory_items")
}

// =============================================================================
// ADMIN & AUDIT
// =============================================================================

model AdminTask {
  id           Int     @id @default(autoincrement())
  status       String  @default("new") @db.VarChar(20)
  priority     String  @default("medium") @db.VarChar(20)
  page         String? @db.VarChar(255)
  page_title   String? @db.VarChar(255)
  description  String? @db.Text
  spec         String? @db.Text
  ai_questions Json?
  ai_answers   Json?
  screenshot   String? @db.Text // base64
  created_by   Int?

  // Soft delete — požadavek se přesune do "Koše" místo fyzického smazání.
  // Autor / admin ho může obnovit nebo trvale smazat.
  deleted_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Vztahy
  creator User? @relation("AdminTaskCreator", fields: [created_by], references: [id], onDelete: SetNull)

  @@index([created_by])
  @@index([status])
  @@index([deleted_at])
  @@map("admin_tasks")
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  timestamp    DateTime @default(now())
  user_name    String?  @db.VarChar(100)
  user_display String?  @db.VarChar(255)
  action       String   @db.VarChar(20) // create, update, delete, rollback
  entity       String   @db.VarChar(50)
  entity_id    Int?
  description  String?  @db.Text
  changes      Json? // { field: { from, to } }
  snapshot     Json? // Kompletní snapshot entity

  @@index([entity, entity_id])
  @@index([timestamp])
  @@map("audit_log")
}

// =============================================================================
// MINDMAPA
// =============================================================================

model MindmapNote {
  id      Int    @id @default(autoincrement())
  key     String @unique @db.VarChar(255) // identifikátor uzlu
  content Json // obsah uzlu
  version Int    @default(1)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("mindmap_notes")
}

// =============================================================================
// VÝROBA — PRODUKTY & PRACOVIŠTĚ (nahrazuje Factorify)
// =============================================================================

model Product {
  id                   Int     @id @default(autoincrement())
  code                 String  @unique @db.VarChar(50) // BS-M-xxxx
  name                 String  @db.VarChar(255)
  type                 String  @default("product") @db.VarChar(50) // product, semi-product
  show_in_configurator Boolean @default(false) // zobrazit v konfigurátoru pro zákazníka a v prodejních objednávkách
  takt_time            Int? // linkový takt v minutách (max čas na operaci)
  factorify_id         Int? // původní ID z Factorify
  material_id          Int? // vazba na Material pokud existuje

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  operations      ProductOperation[]
  bom_usages      OperationMaterial[] // kde se tento produkt používá jako BOM položka
  config_groups   ProductConfigGroup[] // konfigurační skupiny (Rám, Barva, ...)
  pricelist_items SalesPricelistItem[] // položky v prodejním ceníku navázané na výrobek
  order_items     OrderItem[] // položky objednávek, které na tento výrobek odkazují (pro výrobu a výbavu)
  invoice_items   InvoiceItem[]        @relation("InvoiceItemProduct")

  @@index([factorify_id])
  @@map("products")
}

// Prodejní ceník — samostatné prodejní položky s cenami v Kč a EUR bez DPH.
// Volitelně lze položku propojit s Product (výrobkem). Vhodné pro výrobky,
// služby, příslušenství nebo zboží, které zatím nemá výrobní kus.
model SalesPricelistItem {
  id              Int      @id @default(autoincrement())
  name_cs         String   @db.VarChar(255) // název česky (povinný)
  name_en         String?  @db.VarChar(255) // název anglicky
  price_czk       Decimal? @db.Decimal(12, 2) // maloobchodní cena Kč bez DPH
  price_eur       Decimal? @db.Decimal(12, 2) // maloobchodní cena EUR bez DPH
  truck_price_czk Decimal? @db.Decimal(12, 2) // kamionová (velkoobchodní) cena Kč bez DPH
  truck_price_eur Decimal? @db.Decimal(12, 2) // kamionová cena EUR bez DPH
  product_id      Int? // volitelné propojení na Product (když prázdné, UI upozorní červeně)
  product         Product? @relation(fields: [product_id], references: [id], onDelete: SetNull)
  active          Boolean  @default(true) // aktivní / zrušená položka
  note            String?  @db.Text // interní poznámka

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([product_id])
  @@index([active])
  @@map("sales_pricelist_items")
}

// Hala (seskupení pracovišť)
model Hall {
  id         Int    @id @default(autoincrement())
  name       String @db.VarChar(255)
  color      String @default("#14b8a6") @db.VarChar(20) // barva pro rozlišení
  sort_order Int    @default(0) // pořadí zobrazení

  created_at DateTime @default(now())

  workstations Workstation[]

  @@map("halls")
}

model Workstation {
  id           Int     @id @default(autoincrement())
  name         String  @db.VarChar(255)
  code         String? @db.VarChar(50)
  factorify_id Int? // původní Stage ID z Factorify

  // Zařazení do haly
  hall_id Int?

  // Externí pracoviště (kooperace)
  is_external Boolean @default(false)

  // Rozměry pracoviště v metrech
  width_m  Decimal? @db.Decimal(8, 2) // šířka v m
  length_m Decimal? @db.Decimal(8, 2) // délka v m

  // Vstupní a výstupní sklad + pozice
  input_warehouse_id  Int?
  input_location_id   Int?
  output_warehouse_id Int?
  output_location_id  Int?

  created_at DateTime @default(now())

  hall             Hall?               @relation(fields: [hall_id], references: [id], onDelete: SetNull)
  input_warehouse  Warehouse?          @relation("WorkstationInputWarehouse", fields: [input_warehouse_id], references: [id])
  input_location   WarehouseLocation?  @relation("WorkstationInputLocation", fields: [input_location_id], references: [id])
  output_warehouse Warehouse?          @relation("WorkstationOutputWarehouse", fields: [output_warehouse_id], references: [id])
  output_location  WarehouseLocation?  @relation("WorkstationOutputLocation", fields: [output_location_id], references: [id])
  operations       ProductOperation[]
  workers          WorkstationWorker[]
  production_slots ProductionSlot[]

  @@index([hall_id])
  @@index([factorify_id])
  @@index([input_warehouse_id])
  @@index([input_location_id])
  @@index([output_warehouse_id])
  @@index([output_location_id])
  @@map("workstations")
}

// Vazební tabulka: pracovníci přiřazení k pracovišti
model WorkstationWorker {
  id             Int     @id @default(autoincrement())
  workstation_id Int
  person_id      Int
  role           String? @db.VarChar(100) // role na pracovišti (operátor, seřizovač, kontrolor...)
  is_primary     Boolean @default(false) // hlavní pracovník pracoviště

  created_at DateTime @default(now())

  workstation Workstation @relation(fields: [workstation_id], references: [id], onDelete: Cascade)
  person      Person      @relation(fields: [person_id], references: [id], onDelete: Cascade)

  @@unique([workstation_id, person_id])
  @@index([person_id])
  @@map("workstation_workers")
}

model ProductOperation {
  id               Int     @id @default(autoincrement())
  product_id       Int
  workstation_id   Int?
  step_number      Int // pořadí operace
  name             String  @db.VarChar(255)
  phase            String? @db.VarChar(255)
  duration         Int? // trvání v minutách
  duration_unit    String  @default("MINUTE") @db.VarChar(20) // MINUTE, SECOND, HOUR
  preparation_time Int     @default(0)
  workers_count    Int     @default(1) // počet pracovníků na operaci
  description      String? @db.Text // popis operace
  bom_count        Int? // počet BOM položek

  product           Product                 @relation(fields: [product_id], references: [id], onDelete: Cascade)
  workstation       Workstation?            @relation(fields: [workstation_id], references: [id])
  materials         OperationMaterial[]
  config_option_ops ConfigOptionOperation[] // volby, které ovlivňují tuto operaci

  @@index([product_id])
  @@map("product_operations")
}

// Materiály spotřebované v operaci (BOM per operation)
model OperationMaterial {
  id           Int     @id @default(autoincrement())
  operation_id Int
  material_id  Int
  product_id   Int? // přímá vazba na Product (pokud je to výrobek/polotovar)
  quantity     Decimal @db.Decimal(10, 3) // spotřeba materiálu
  unit         String  @default("ks") @db.VarChar(20)

  operation ProductOperation @relation(fields: [operation_id], references: [id], onDelete: Cascade)
  material  Material         @relation(fields: [material_id], references: [id])
  product   Product?         @relation(fields: [product_id], references: [id])

  @@index([operation_id])
  @@index([material_id])
  @@index([product_id])
  @@map("operation_materials")
}

// =============================================================================
// VÝROBA — SIMULACE
// =============================================================================

model Simulation {
  id          String @id @default(uuid())
  name        String @db.VarChar(255)
  version     Int    @default(1)
  objects     Json // pole objektů (areály, stroje, atd.)
  connections Json? // pole propojení
  viewport    Json? // { zoom, panX, panY }

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("simulations")
}

// =============================================================================
// AI ASISTENTI & SKILLY
// =============================================================================

model Assistant {
  id            String  @id @default(uuid())
  name          String  @db.VarChar(255)
  slug          String  @unique @db.VarChar(100)
  role          String  @db.Text
  system_prompt String  @db.Text
  model         String  @default("claude-sonnet-4-6") @db.VarChar(100)
  avatar_url    String? @db.VarChar(255)
  is_active     Boolean @default(true)
  config        Json?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  skills        AssistantSkill[]
  conversations Conversation[]

  @@map("assistants")
}

model Skill {
  id             String  @id @default(uuid())
  name           String  @db.VarChar(255)
  slug           String  @unique @db.VarChar(100)
  description    String  @db.Text
  category       String  @db.VarChar(50) // system, hr, warehouse, production, tasks
  handler_type   String  @db.VarChar(50) // mcp_tool, api_call, db_query, external
  handler_config Json?
  input_schema   Json? // JSON Schema
  output_schema  Json? // JSON Schema
  requires_auth  Boolean @default(true)
  is_active      Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  assistants AssistantSkill[]
  executions SkillExecution[]

  @@map("skills")
}

model AssistantSkill {
  assistant_id    String
  skill_id        String
  priority        Int    @default(0)
  config_override Json?

  assistant Assistant @relation(fields: [assistant_id], references: [id], onDelete: Cascade)
  skill     Skill     @relation(fields: [skill_id], references: [id], onDelete: Cascade)

  @@id([assistant_id, skill_id])
  @@map("assistant_skills")
}

model Conversation {
  id           String  @id @default(uuid())
  user_id      Int
  assistant_id String
  title        String? @db.VarChar(255)
  context      Json? // { module, page, extra_data }

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  assistant Assistant @relation(fields: [assistant_id], references: [id])
  messages  Message[]

  @@index([user_id])
  @@index([assistant_id])
  @@map("conversations")
}

model Message {
  id              String @id @default(uuid())
  conversation_id String
  role            String @db.VarChar(20) // user, assistant, system
  content         String @db.Text
  skill_calls     Json? // [{ skill_id, input, output }]

  created_at DateTime @default(now())

  conversation Conversation     @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  executions   SkillExecution[]

  @@index([conversation_id])
  @@map("messages")
}

model SkillExecution {
  id          String @id @default(uuid())
  message_id  String
  skill_id    String
  input       Json?
  output      Json?
  status      String @db.VarChar(20) // success, error, timeout
  duration_ms Int?

  created_at DateTime @default(now())

  message Message @relation(fields: [message_id], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skill_id], references: [id])

  @@index([skill_id])
  @@index([created_at])
  @@map("skill_executions")
}

model DevAgent {
  id            String  @id @default(uuid())
  slug          String  @unique @db.VarChar(100)
  name          String  @db.VarChar(255)
  icon          String  @default("🤖") @db.VarChar(10)
  module        String? @db.VarChar(100) // mapování na modul (lide-hr, nakup-sklad, ...)
  context_file  String? @db.VarChar(255) // cesta ke kontextovému souboru (.claude/agents/*.md)
  system_prompt String  @db.Text // system prompt pro Claude
  model         String  @default("claude-sonnet-4-6") @db.VarChar(100)
  is_active     Boolean @default(true)
  color         String  @default("#8b5cf6") @db.VarChar(20)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("dev_agents")
}

// =============================================================================
// PRODUKTOVÝ KONFIGURÁTOR — variabilní výbava výrobků
// =============================================================================

// Konfigurační skupina (řádek na objednávkovém listu: Rám, Barva opláštění, Polepy, ...)
model ProductConfigGroup {
  id         Int     @id @default(autoincrement())
  product_id Int
  name       String  @db.VarChar(255) // např. "Rám", "Barva opláštění"
  code       String  @db.VarChar(100) // strojový kód: "ram", "barva_oplasteni"
  type       String  @default("single_select") @db.VarChar(50) // single_select, multi_select, boolean, text
  required   Boolean @default(false) // musí zákazník vybrat?
  sort_order Int     @default(0) // pořadí zobrazení

  product Product               @relation(fields: [product_id], references: [id], onDelete: Cascade)
  options ProductConfigOption[]

  @@unique([product_id, code])
  @@index([product_id])
  @@map("product_config_groups")
}

// Konfigurační volba (možnost v rámci skupiny: Fe natíraný, Nerez, ...)
model ProductConfigOption {
  id             Int     @id @default(autoincrement())
  group_id       Int
  name           String  @db.VarChar(255) // např. "Fe natíraný", "Nerez"
  code           String  @db.VarChar(100) // strojový kód: "fe_natirany", "nerez"
  price_modifier Decimal @default(0) @db.Decimal(10, 2) // příplatek/sleva k ceně
  is_default     Boolean @default(false) // výchozí volba
  sort_order     Int     @default(0)

  group             ProductConfigGroup      @relation(fields: [group_id], references: [id], onDelete: Cascade)
  bom_materials     ConfigOptionMaterial[] // materiály potřebné pro tuto volbu
  operation_effects ConfigOptionOperation[] // vliv na operace v pracovním postupu
  order_configs     OrderItemConfig[] // objednávky s touto volbou

  @@unique([group_id, code])
  @@index([group_id])
  @@map("product_config_options")
}

// Vazba volba → materiál (BOM): jaké materiály se přidají/nahradí při výběru volby
model ConfigOptionMaterial {
  id          Int     @id @default(autoincrement())
  option_id   Int
  material_id Int
  quantity    Decimal @db.Decimal(10, 3)
  unit        String  @default("ks") @db.VarChar(20)

  option   ProductConfigOption @relation(fields: [option_id], references: [id], onDelete: Cascade)
  material Material            @relation(fields: [material_id], references: [id])

  @@index([option_id])
  @@index([material_id])
  @@map("config_option_materials")
}

// Vazba volba → operace: jak volba ovlivní pracovní postup
model ConfigOptionOperation {
  id                Int     @id @default(autoincrement())
  option_id         Int
  operation_id      Int
  action            String  @db.VarChar(20) // "add" = přidej operaci, "skip" = přeskoč, "modify" = uprav
  modified_duration Int? // upravená doba trvání (minuty), pokud action = "modify"
  note              String? @db.VarChar(255) // poznámka pro výrobu

  option    ProductConfigOption @relation(fields: [option_id], references: [id], onDelete: Cascade)
  operation ProductOperation    @relation(fields: [operation_id], references: [id], onDelete: Cascade)

  @@index([option_id])
  @@index([operation_id])
  @@map("config_option_operations")
}

// Vybraná konfigurace na položce prodejní objednávky
model OrderItemConfig {
  id            Int     @id @default(autoincrement())
  order_item_id Int
  option_id     Int? // vybraná volba (pro single_select, multi_select, boolean)
  custom_value  String? @db.VarChar(500) // vlastní hodnota (pro type "text" nebo "jiná barva")

  order_item OrderItem            @relation(fields: [order_item_id], references: [id], onDelete: Cascade)
  option     ProductConfigOption? @relation(fields: [option_id], references: [id])

  @@index([order_item_id])
  @@index([option_id])
  @@map("order_item_configs")
}

// =============================================================================
// VÝROBNÍ SLOTY — časová okna výroby
// =============================================================================

// Výrobní slot = časové okno, do kterého se řadí zakázky
model ProductionSlot {
  id             Int      @id @default(autoincrement())
  name           String   @db.VarChar(255) // např. "Týden 16 — Linka A"
  workstation_id Int? // volitelná vazba na pracoviště
  start_date     DateTime @db.Date // začátek slotu
  end_date       DateTime @db.Date // konec slotu
  capacity_hours Decimal  @default(8) @db.Decimal(8, 2) // kapacita v hodinách za den
  status         String   @default("open") @db.VarChar(20) // open, full, blocked, closed
  color          String   @default("#3b82f6") @db.VarChar(20)
  note           String?  @db.Text

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  workstation Workstation?     @relation(fields: [workstation_id], references: [id], onDelete: SetNull)
  assignments SlotAssignment[]
  blocks      SlotBlock[]

  @@index([workstation_id])
  @@index([start_date])
  @@index([end_date])
  @@index([status])
  @@map("production_slots")
}

// Přiřazení objednávky/produktu do slotu
model SlotAssignment {
  id              Int     @id @default(autoincrement())
  slot_id         Int
  order_id        Int? // vazba na objednávku
  order_item_id   Int? // vazba na konkrétní položku objednávky
  product_name    String  @db.VarChar(255) // název produktu (denormalizováno pro rychlý přehled)
  customer_name   String? @db.VarChar(255) // zákazník
  quantity        Decimal @default(1) @db.Decimal(10, 2)
  estimated_hours Decimal @default(0) @db.Decimal(8, 2) // odhadovaný čas výroby
  priority        Int     @default(0) // vyšší = důležitější
  status          String  @default("planned") @db.VarChar(20) // planned, in_progress, done
  note            String? @db.Text

  created_at DateTime @default(now())

  slot       ProductionSlot @relation(fields: [slot_id], references: [id], onDelete: Cascade)
  order_item OrderItem?     @relation(fields: [order_item_id], references: [id], onDelete: SetNull)

  @@index([slot_id])
  @@index([order_id])
  @@index([order_item_id])
  @@index([status])
  @@map("slot_assignments")
}

// Blokace slotu — dovolená, údržba, nepracovní dny apod.
model SlotBlock {
  id         Int      @id @default(autoincrement())
  slot_id    Int
  start_date DateTime @db.Date
  end_date   DateTime @db.Date
  reason     String   @db.VarChar(255) // "Dovolená", "Údržba stroje", "Státní svátek"
  block_type String   @default("holiday") @db.VarChar(30) // holiday, maintenance, other

  created_at DateTime @default(now())

  slot ProductionSlot @relation(fields: [slot_id], references: [id], onDelete: Cascade)

  @@index([slot_id])
  @@index([start_date])
  @@map("slot_blocks")
}

// =============================================================================
// MESSAGING — user-to-user chat, skupinové kanály, thready u požadavků, AI účastník
// Oddělené od Conversation/Message (ty slouží pro AI asistenty se skill_calls)
// =============================================================================

model ChatChannel {
  id              String   @id @default(uuid())
  type            String   @db.VarChar(20) // direct | group | task | system
  name            String?  @db.VarChar(255) // null pro direct - renderuje se z protistrany
  topic           String?  @db.VarChar(500)
  admin_task_id   Int? // vazba na požadavek (pro type = 'task')
  created_by      Int?
  last_message_at DateTime @default(now())

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  creator  User?               @relation("ChatChannelCreator", fields: [created_by], references: [id], onDelete: SetNull)
  members  ChatChannelMember[]
  messages ChatMessage[]

  @@unique([type, admin_task_id]) // jeden task kanál = jeden požadavek
  @@index([type])
  @@index([last_message_at])
  @@index([admin_task_id])
  @@map("chat_channels")
}

model ChatChannelMember {
  id           Int       @id @default(autoincrement())
  channel_id   String
  user_id      Int
  role         String    @default("member") @db.VarChar(20) // member | admin
  joined_at    DateTime  @default(now())
  last_read_at DateTime? // null = nic nepřečteno
  muted        Boolean   @default(false)

  channel ChatChannel @relation(fields: [channel_id], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([channel_id, user_id])
  @@index([user_id])
  @@map("chat_channel_members")
}

model ChatMessage {
  id           String    @id @default(uuid())
  channel_id   String
  sender_id    Int? // null pro 'system' a 'ai' (odesílatel z back-endu)
  sender_type  String    @default("user") @db.VarChar(20) // user | system | ai
  sender_label String?   @db.VarChar(255) // přezdívka pro system/ai ("HolyOS", "Claude")
  content      String    @db.Text
  attachments  Json? // [{ kind, url, name }]
  edited_at    DateTime?
  deleted_at   DateTime?

  created_at DateTime @default(now())

  channel ChatChannel @relation(fields: [channel_id], references: [id], onDelete: Cascade)
  sender  User?       @relation("ChatMessageSender", fields: [sender_id], references: [id], onDelete: SetNull)

  @@index([channel_id, created_at])
  @@index([sender_id])
  @@map("chat_messages")
}

model Notification {
  id      String    @id @default(uuid())
  user_id Int
  type    String    @db.VarChar(50) // chat_message | task_status | task_deployed | mention | system
  title   String    @db.VarChar(255)
  body    String?   @db.Text
  link    String?   @db.VarChar(500) // URL nebo route
  meta    Json? // { channel_id, message_id, task_id, ... }
  read_at DateTime?

  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, read_at])
  @@index([created_at])
  @@map("notifications")
}

// =============================================================================
// VOZOVÝ PARK — VEHICLE FLEET
// =============================================================================

model Vehicle {
  id Int @id @default(autoincrement())

  // Identifikace vozidla
  license_plate String? @db.VarChar(20) // SPZ
  company       String? @db.VarChar(100) // Vlastník/provozovatel: "Best Series" | "Špagetka" | "JTP services"
  model         String  @db.VarChar(255) // Vozidlo / model (např. "Hyundai i30")
  vin           String? @db.VarChar(30) // VIN kód
  category      String  @db.VarChar(50) // "Osobní vůz" | "Dodávka" | "Nákladní" | "Motocykl" | "Jiné"
  color         String? @db.VarChar(50)
  year          Int? // Rok výroby

  // Povinné ručení (POV)
  insurance_from    DateTime? @db.Date
  insurance_to      DateTime? @db.Date
  insurance_company String?   @db.VarChar(255)

  // STK — Státní technická kontrola
  stk_valid_to DateTime? @db.Date

  // Dálniční známka
  toll_sticker_to DateTime? @db.Date

  // Financování / vlastnictví
  // "operativni_leasing" | "vlastnictvi_firmy" | "financni_leasing" | "uver" | "jine"
  financing_type  String?   @db.VarChar(50)
  financing_to    DateTime? @db.Date
  financing_owner String?   @db.VarChar(255) // Např. "Best Series s.r.o.", "ESSOX s.r.o."

  // Disky a pneu
  disk_size String? @db.VarChar(255)
  tire_size String? @db.VarChar(255)

  // Řidič / odpovědná osoba
  driver_id Int?
  driver    Person? @relation("VehicleDriver", fields: [driver_id], references: [id], onDelete: SetNull)

  // Stav vozidla
  active     Boolean @default(true) // Aktivní/vyřazeno
  current_km Int? // Aktuální kilometry
  note       String? @db.Text

  // Vztahy k rozšíření fleet managementu (dokumenty, servisy, pneu, škody)
  documents          VehicleDocument[]
  insurance_policies VehicleInsurancePolicy[]
  services           VehicleService[]
  tire_changes       VehicleTireChange[]
  damage_events      VehicleDamageEvent[]
  tire_stock         TireStockItem[]

  // Účetní doklady — náklady na konkrétní auto (palivo, servis, pojistka)
  invoice_items InvoiceItem[] @relation("InvoiceItemVehicle")
  cost_centers  CostCenter[]  @relation("CostCenterVehicle")

  // Systémové
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([license_plate])
  @@index([company])
  @@index([vin])
  @@index([category])
  @@index([driver_id])
  @@index([active])
  @@index([insurance_to])
  @@index([stk_valid_to])
  @@index([toll_sticker_to])
  @@map("vehicles")
}

// Dokumentace vozu — technický průkaz, leasingová smlouva, STK protokoly atd.
model VehicleDocument {
  id         Int     @id @default(autoincrement())
  vehicle_id Int
  vehicle    Vehicle @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)

  // Typ dokumentu: "technicky_prukaz" | "stk_protokol" | "smlouva" | "protokol" | "jine"
  // (Hodnota "leasing" zůstává podporována pro zpětnou kompatibilitu starších záznamů.)
  doc_type  String  @db.VarChar(50)
  title     String  @db.VarChar(255) // Popisek (např. "Technický průkaz - list A")
  file_url  String  @db.VarChar(500) // /api/storage/files/vehicles/...
  file_name String? @db.VarChar(255) // Původní název souboru
  file_size Int? // v bytech
  mime_type String? @db.VarChar(100)
  note      String? @db.Text

  uploaded_at DateTime @default(now())
  uploaded_by Int? // User.id (kdo nahrál)

  @@index([vehicle_id])
  @@index([doc_type])
  @@map("vehicle_documents")
}

// Pojistky — povinné ručení a havarijní, s platností a přiloženým dokumentem
model VehicleInsurancePolicy {
  id         Int     @id @default(autoincrement())
  vehicle_id Int
  vehicle    Vehicle @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)

  // Typ: "pov" (povinné ručení) | "havarijni" | "jine"
  policy_type    String    @db.VarChar(30)
  company_name   String?   @db.VarChar(255) // Pojišťovna
  policy_number  String?   @db.VarChar(100) // Číslo pojistky
  valid_from     DateTime? @db.Date
  valid_to       DateTime? @db.Date
  premium_amount Decimal?  @db.Decimal(12, 2) // Pojistné (Kč)
  file_url       String?   @db.VarChar(500) // Scan/PDF
  file_name      String?   @db.VarChar(255)
  note           String?   @db.Text

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([vehicle_id])
  @@index([policy_type])
  @@index([valid_to])
  @@map("vehicle_insurance_policies")
}

// Servisy — pravidelné + ad-hoc. Plán, provedení, cena, faktura.
model VehicleService {
  id         Int     @id @default(autoincrement())
  vehicle_id Int
  vehicle    Vehicle @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)

  // Stav: "planned" (naplánováno, čeká na provedení)
  //     | "done" (provedeno a potvrzeno správcem)
  //     | "cancelled"
  status String @default("planned") @db.VarChar(20)

  service_type        String    @db.VarChar(255) // Např. "Pravidelný servis", "Výměna oleje", volný text
  scheduled_at        DateTime? // Plánovaný termín (datum + čas)
  done_at             DateTime? // Kdy skutečně proběhlo
  // Napojení na firmu v adresáři (preferovaný zdroj pravdy). Textové pole service_company
  // zůstává pro zpětnou kompatibilitu starších záznamů a při mazání firmy z adresáře.
  service_company_id  Int?
  service_company_ref Company?  @relation("VehicleServiceCompany", fields: [service_company_id], references: [id], onDelete: SetNull)
  service_company     String?   @db.VarChar(255) // Denormalizovaný název firmy (kvůli historii / mazání)
  // Místo provedení (volný text) — zachováno jako fallback pro starší záznamy
  // a pro případ, kdy uživatel zadal lokaci ručně mimo adresář provozoven.
  // Preferovaný zdroj pravdy je M2N relace `branches` (VehicleServiceLocation).
  location            String?   @db.VarChar(500)
  km_at_service       Int? // Stav kilometrů při servisu
  order_number        String?   @db.VarChar(100) // Číslo zakázky

  cost_labor     Decimal? @db.Decimal(12, 2) // Cena za práci (Kč)
  cost_parts     Decimal? @db.Decimal(12, 2) // Cena za díly (Kč)
  invoice_url    String?  @db.VarChar(500) // Napojená faktura (storage URL)
  invoice_number String?  @db.VarChar(100)

  note         String?   @db.Text
  confirmed_by Int? // User.id správce, který potvrdil provedení
  confirmed_at DateTime?

  created_at DateTime @default(now())
  created_by Int?
  updated_at DateTime @updatedAt

  // Místa provedení (M2N) — vybraná z provozoven firmy provádějící servis.
  branches VehicleServiceLocation[]

  @@index([vehicle_id])
  @@index([status])
  @@index([scheduled_at])
  @@index([service_company_id])
  @@map("vehicle_services")
}

// Výměny pneu — plán, provedení, cena (zvlášť úkon + samotné pneu)
model VehicleTireChange {
  id         Int     @id @default(autoincrement())
  vehicle_id Int
  vehicle    Vehicle @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)

  // Stav: "planned" | "done" | "cancelled"
  status String @default("planned") @db.VarChar(20)

  // Sezóna: "letni" | "zimni"
  season String @db.VarChar(10)

  scheduled_at        DateTime? // Plánovaný termín
  done_at             DateTime?
  // Místo výměny (volný text) — zachováno jako fallback. Preferovaný zdroj pravdy
  // je M2N relace `branches` (VehicleTireChangeLocation).
  location            String?   @db.VarChar(500)
  km_at_service       Int? // Stav kilometrů při výměně
  order_number        String?   @db.VarChar(100) // Číslo zakázky
  // Napojení na firmu v adresáři (preferovaný zdroj pravdy). Textové pole service_company
  // zůstává pro zpětnou kompatibilitu starších záznamů a při mazání firmy z adresáře.
  service_company_id  Int?
  service_company_ref Company?  @relation("VehicleTireCompany", fields: [service_company_id], references: [id], onDelete: SetNull)
  service_company     String?   @db.VarChar(255) // Denormalizovaný název firmy (kvůli historii / mazání)

  // Oddělená cena: úkon (výměna/vyvážení) vs. nové pneu
  cost_service Decimal? @db.Decimal(12, 2) // Cena za úkon — výměna, vyvážení atd.
  cost_tires   Decimal? @db.Decimal(12, 2) // Cena za pneu (když byly kupovány nové)

  invoice_url    String? @db.VarChar(500)
  invoice_number String? @db.VarChar(100)
  // Protokol / dodací list (PDF nebo obrázek) — uložený ve storage stejně
  // jako faktura. Slouží k záznamu předávacího protokolu, dodacího listu od
  // pneuservisu nebo jiné technické dokumentace ke konkrétní výměně.
  protocol_url   String? @db.VarChar(500)

  note         String?   @db.Text
  confirmed_by Int?
  confirmed_at DateTime?

  created_at DateTime @default(now())
  created_by Int?
  updated_at DateTime @updatedAt

  // Místa provedení (M2N) — vybraná z provozoven pneuservisu.
  branches VehicleTireChangeLocation[]

  @@index([vehicle_id])
  @@index([status])
  @@index([scheduled_at])
  @@index([season])
  @@index([service_company_id])
  @@map("vehicle_tire_changes")
}

// Provozovny firem (adresář) — každá Company může mít více provozoven.
// Vznikají v Adresáři firem tlačítkem +Přidat. V Servisu / Pneu management
// se vybírají jako Místo provedení (může jich být více najednou).
model CompanyBranch {
  id         Int     @id @default(autoincrement())
  company_id Int
  company    Company @relation("CompanyBranches", fields: [company_id], references: [id], onDelete: Cascade)

  name           String? @db.VarChar(255) // Název pobočky (např. "Brno - Olomoucká")
  address        String? @db.VarChar(255)
  city           String? @db.VarChar(100)
  zip            String? @db.VarChar(10)
  contact_person String? @db.VarChar(255)
  phone          String? @db.VarChar(50)
  email          String? @db.VarChar(255)
  note           String? @db.Text
  active         Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  service_locations VehicleServiceLocation[]
  tire_locations    VehicleTireChangeLocation[]

  @@index([company_id])
  @@map("company_branches")
}

// M2N: VehicleService ↔ CompanyBranch (více míst provedení pro jeden servis)
model VehicleServiceLocation {
  service_id Int
  branch_id  Int

  service VehicleService @relation(fields: [service_id], references: [id], onDelete: Cascade)
  branch  CompanyBranch  @relation(fields: [branch_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now())

  @@id([service_id, branch_id])
  @@index([service_id])
  @@index([branch_id])
  @@map("vehicle_service_locations")
}

// M2N: VehicleTireChange ↔ CompanyBranch (více míst provedení pro jednu výměnu)
model VehicleTireChangeLocation {
  tire_change_id Int
  branch_id      Int

  tire_change VehicleTireChange @relation(fields: [tire_change_id], references: [id], onDelete: Cascade)
  branch      CompanyBranch     @relation(fields: [branch_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now())

  @@id([tire_change_id, branch_id])
  @@index([tire_change_id])
  @@index([branch_id])
  @@map("vehicle_tire_change_locations")
}

// Škodní události — datum, místo, popis, přílohy
model VehicleDamageEvent {
  id         Int     @id @default(autoincrement())
  vehicle_id Int
  vehicle    Vehicle @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)

  event_date       DateTime // Datum události
  location         String?  @db.VarChar(500) // Místo události
  description      String?  @db.Text
  claim_number     String?  @db.VarChar(100) // Číslo škodní události u pojišťovny
  estimated_damage Decimal? @db.Decimal(12, 2) // Odhadovaná škoda (Kč)

  documents VehicleDamageDocument[]

  created_at DateTime @default(now())
  created_by Int?
  updated_at DateTime @updatedAt

  @@index([vehicle_id])
  @@index([event_date])
  @@map("vehicle_damage_events")
}

model VehicleDamageDocument {
  id              Int                @id @default(autoincrement())
  damage_event_id Int
  damage_event    VehicleDamageEvent @relation(fields: [damage_event_id], references: [id], onDelete: Cascade)

  title       String?  @db.VarChar(255)
  file_url    String   @db.VarChar(500)
  file_name   String?  @db.VarChar(255)
  mime_type   String?  @db.VarChar(100)
  file_size   Int?
  uploaded_at DateTime @default(now())
  uploaded_by Int?

  @@index([damage_event_id])
  @@map("vehicle_damage_documents")
}

// Sklad pneu — fyzické pneumatiky na skladě, přiřazené vozidlu (či volné)
// Sledujeme hloubku dezénu a pozici ve skladu.
model TireStockItem {
  id Int @id @default(autoincrement())

  // Přiřazení vozidlu (volitelné — může být i univerzální zásoba)
  vehicle_id Int?
  vehicle    Vehicle? @relation(fields: [vehicle_id], references: [id], onDelete: SetNull)

  // Sezóna: "letni" | "zimni"
  season String @db.VarChar(10)

  // Rozměr a výrobce
  tire_size    String? @db.VarChar(100) // např. "205/55 R16 91H"
  manufacturer String? @db.VarChar(100)
  model_name   String? @db.VarChar(255)
  dot_code     String? @db.VarChar(20) // DOT kód (týden/rok výroby)

  // Stav dezénu — v mm, pro hlídání hranic (letní 2-3 mm, zimní 4-5 mm = upozornění)
  tread_depth_mm Decimal? @db.Decimal(4, 1)

  // Lokace ve skladu (volný text: "Regál A3", "Sklad B — pozice 14")
  storage_location String? @db.VarChar(255)

  // Namontováno = aktuálně na voze; false = na skladě
  mounted       Boolean   @default(false)
  mounted_at    DateTime?
  dismounted_at DateTime?

  // Odkaz na nákupní fakturu (nepovinné)
  purchase_price Decimal? @db.Decimal(12, 2)
  invoice_url    String?  @db.VarChar(500)
  invoice_number String?  @db.VarChar(100)

  note String? @db.Text

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([vehicle_id])
  @@index([season])
  @@index([mounted])
  @@map("tire_stock_items")
}

// =============================================================================
// CAD — SolidWorks výkresy, sestavy, kusovníky
// Import ze SolidWorksu přes desktop klienta (kontextové menu "Odevzdat do výroby").
// Původně tok CadExporter → Factorify, migrováno do HolyOS (/api/cad/*).
// =============================================================================

// Projekt = nejvyšší úroveň (zakázka / produktová řada)
model CadProject {
  id          Int     @id @default(autoincrement())
  code        String  @unique @db.VarChar(50) // krátký kód projektu, unikátní
  name        String  @db.VarChar(255)
  customer    String? @db.VarChar(255)
  description String? @db.Text
  active      Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  blocks   CadBlock[]
  drawings CadDrawing[]

  @@index([code])
  @@index([active])
  @@map("cad_projects")
}

// Blok = uzel ve stromu projektu (odpovídá Factorify "goodsBlock")
model CadBlock {
  id         Int     @id @default(autoincrement())
  project_id Int
  parent_id  Int?
  name       String  @db.VarChar(255)
  label      String? @db.VarChar(255) // TokenizedLabel z původního API (volitelné)
  sort_order Int     @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  project  CadProject   @relation(fields: [project_id], references: [id], onDelete: Cascade)
  parent   CadBlock?    @relation("CadBlockTree", fields: [parent_id], references: [id], onDelete: SetNull)
  children CadBlock[]   @relation("CadBlockTree")
  drawings CadDrawing[]

  @@index([project_id])
  @@index([parent_id])
  @@map("cad_blocks")
}

// Výkres / díl / sestava — jeden soubor ze SolidWorksu
model CadDrawing {
  id         Int  @id @default(autoincrement())
  project_id Int
  block_id   Int?

  // Identifikace
  file_name     String  @db.VarChar(255) // např. "12345-01.SLDDRW"
  relative_path String? @db.VarChar(500)
  extension     String  @db.VarChar(10) // "sldprt" | "sldasm" | "slddrw" | "stl"
  version       Int     @default(1)
  checksum      String? @db.VarChar(64) // SHA256 binárního souboru
  feature_hash  String? @db.VarChar(64) // SHA256 feature-tree ze SW — reálný indikátor změny geometrie
  source_path   String? @db.VarChar(1000) // původní cesta na disku autora

  // Metadata
  title       String? @db.VarChar(255) // pěkný název (z custom property)
  description String? @db.Text

  // Autor / vlastnictví
  created_by_id  Int?
  imported_at    DateTime @default(now())
  last_import_at DateTime @default(now())

  // Systémové
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  project        CadProject            @relation(fields: [project_id], references: [id], onDelete: Cascade)
  block          CadBlock?             @relation(fields: [block_id], references: [id], onDelete: SetNull)
  creator        Person?               @relation("CadDrawingCreator", fields: [created_by_id], references: [id], onDelete: SetNull)
  configurations CadDrawingConfig[]
  change_logs    CadDrawingChangeLog[]

  @@unique([project_id, file_name, version])
  @@index([project_id])
  @@index([block_id])
  @@index([extension])
  @@index([file_name])
  @@map("cad_drawings")
}

// Historie změn výkresu — každý úspěšný import (create / update) zaznamená
// autora, verze, váhu změny a volitelnou poznámku od konstruktéra.
// Zobrazuje se v detailu výkresu jako časová osa.
model CadDrawingChangeLog {
  id          Int      @id @default(autoincrement())
  drawing_id  Int
  author_id   Int?
  action      String   @db.VarChar(20) // "created" | "updated"
  weight      String?  @db.VarChar(20) // "minor" | "medium" | "major" | null
  note        String?  @db.Text
  old_version Int?
  new_version Int
  created_at  DateTime @default(now())

  drawing CadDrawing @relation(fields: [drawing_id], references: [id], onDelete: Cascade)
  author  Person?    @relation("CadDrawingChangeLogAuthor", fields: [author_id], references: [id], onDelete: SetNull)

  @@index([drawing_id])
  @@index([created_at])
  @@map("cad_drawing_change_logs")
}

// Konfigurace výkresu — SolidWorks umí mít více konfigurací v jednom souboru
// (varianty rozměrů, provedení). Pro každou se generuje vlastní PDF/PNG.
model CadDrawingConfig {
  id         Int @id @default(autoincrement())
  drawing_id Int

  config_name String  @db.VarChar(255) // např. "Default", "Levá varianta"
  config_code String? @db.VarChar(100) // ConfigurationID z SW
  quantity    Int     @default(1) // počet ks při odevzdání
  selected    Boolean @default(true)

  custom_properties Json     @default("{}") // všechny custom props karty
  mass_grams        Decimal? @db.Decimal(12, 3) // hmotnost z GetMassProperties

  png_path String? @db.VarChar(500) // cesta uloženého PNG náhledu
  pdf_path String? @db.VarChar(500) // cesta uloženého PDF výkresu
  stl_path String? @db.VarChar(500) // cesta uloženého STL pro 3D web viewer (Three.js)

  // Další přílohy — .step, .dxf, .easm, .eprt, .iges atd. Formát:
  // [{ kind: "step", filename: "BS-S-0325.step", path: "2026/04/ab12…step", size: 123456 }]
  attachments Json @default("[]")

  // Externí reference (odkazy na další SW soubory)
  external_references Json @default("[]")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  drawing    CadDrawing     @relation(fields: [drawing_id], references: [id], onDelete: Cascade)
  components CadComponent[]

  @@unique([drawing_id, config_name])
  @@index([drawing_id])
  @@map("cad_drawing_configs")
}

// Komponenta = položka v kusovníku sestavy (.sldasm)
// "UnknownComponents" = ty, které index nerozpoznal a čekají na dořešení
model CadComponent {
  id               Int @id @default(autoincrement())
  parent_config_id Int

  name              String  @db.VarChar(255)
  path              String? @db.VarChar(1000)
  quantity          Int     @default(1)
  configuration     String? @db.VarChar(255)
  custom_properties Json?
  is_unknown        Boolean @default(false) // true = index nenašel odpovídající díl
  material_id       Int? // napojení na HolyOS katalog materiálů
  resolved          Boolean @default(false)

  created_at DateTime @default(now())

  parent_config CadDrawingConfig @relation(fields: [parent_config_id], references: [id], onDelete: Cascade)
  material      Material?        @relation(fields: [material_id], references: [id], onDelete: SetNull)

  @@index([parent_config_id])
  @@index([material_id])
  @@index([is_unknown])
  @@map("cad_components")
}

// =============================================================================
// SKLAD 2.0 — PWA ČTEČKA + CENTRÁLNÍ TISK (2026-04)
//
// Nové entity pro skladový modul s podporou PWA na SUNMI L2H/L3 čtečce,
// offline-first provoz (dedup přes client_uuid), pickovací dávky a
// centrální tisk etiket přes TSC TC200 v ZPL.
//
// Doplňuje stávající Warehouse / WarehouseLocation / Material /
// InventoryMovement / Inventory — nenahrazuje je.
// =============================================================================

// Aktuální zásoba dané položky na konkrétní lokaci.
// Transakčně udržovaná z InventoryMovement — rychlý lookup pro čtečku.
model Stock {
  id                Int     @id @default(autoincrement())
  material_id       Int
  location_id       Int
  lot_id            Int? // SKLAD 2.0 — šarže (jen pokud Material.expirable nebo distinguish_batches)
  quantity          Decimal @default(0) @db.Decimal(12, 3)
  reserved_quantity Decimal @default(0) @db.Decimal(12, 3) // rezervováno pro otevřené dávky/výdejky

  updated_at DateTime @updatedAt

  material Material          @relation(fields: [material_id], references: [id])
  location WarehouseLocation @relation(fields: [location_id], references: [id])
  lot      MaterialLot?      @relation(fields: [lot_id], references: [id])

  // Triplet unique — pro nešaržované materiály (lot_id = NULL) PostgreSQL NULL != NULL,
  // takže potenciálně dva záznamy [material, location, NULL]. Business logika v
  // moves.service.js musí takové duplicity hlídat (zatím: upsert po kompozitním klíči).
  @@unique([material_id, location_id, lot_id])
  @@index([location_id])
  @@index([material_id])
  @@index([lot_id])
  @@map("stock")
}

// SKLAD 2.0 — Šarže (lot) pro materiály s expirací nebo rozlišováním dávek.
// Typický use case: prádelna (detergenty s expirací, sledujeme od které šarže
// byl odebrán kus do konkrétního cyklu), potraviny, chemikálie.
// FIFO podle expires_at se řeší v services/warehouse/lots.service.js pickFIFO.
model MaterialLot {
  id          Int    @id @default(autoincrement())
  material_id Int
  lot_code    String @db.VarChar(100)
  status      String @default("in_stock") @db.VarChar(20) // in_stock, consumed, expired, scrapped

  manufactured_at DateTime? @db.Date
  expires_at      DateTime? @db.Date

  supplier_id      Int?
  supplier_lot_ref String? @db.VarChar(100) // externí lot reference od dodavatele

  received_at      DateTime?
  received_move_id Int?
  received_by      Int?

  note       String?  @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  material        Material           @relation(fields: [material_id], references: [id], onDelete: Cascade)
  supplier        Company?           @relation("MaterialLotSupplier", fields: [supplier_id], references: [id])
  received_move   InventoryMovement? @relation("MaterialLotReceivedMove", fields: [received_move_id], references: [id])
  received_person Person?            @relation("MaterialLotReceivedBy", fields: [received_by], references: [id])
  stock_rows      Stock[] // Stock záznamy v různých lokacích pro tuto šarži

  @@unique([material_id, lot_code])
  @@index([material_id])
  @@index([status])
  @@index([expires_at])
  @@index([supplier_id])
  @@map("material_lots")
}

// Skladový dokument — zastřešuje skupinu pohybů (dodací list, výdejka, přesunka,
// pickovací list, inventurní protokol). Append-only princip: dokument se
// uzavře (completed) a dál se needituje — oprava je novým opačným dokumentem.
model WarehouseDocument {
  id           Int       @id @default(autoincrement())
  type         String    @db.VarChar(30) // receipt_doc, issue_doc, transfer_doc, pick_list, inventory_doc
  number       String    @unique @db.VarChar(50) // řada per typ, např. PR-2026-00123
  status       String    @default("draft") @db.VarChar(20) // draft, in_progress, completed, cancelled
  partner_id   Int? // dodavatel / odběratel / projekt (Company)
  reference    String?   @db.VarChar(255) // volný text — číslo DL od dodavatele apod.
  note         String?   @db.Text
  created_by   Int?
  completed_at DateTime?
  completed_by Int?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  partner   Company?            @relation("WarehouseDocumentPartner", fields: [partner_id], references: [id])
  creator   Person?             @relation("WarehouseDocumentCreator", fields: [created_by], references: [id])
  movements InventoryMovement[] // pohyby patřící tomuto dokumentu
  invoices  Invoice[]           @relation("InvoiceWarehouseDoc") // faktury vázané na tento doklad (AP příjemka, AR dodací list)

  @@index([type])
  @@index([status])
  @@index([partner_id])
  @@index([created_at])
  @@map("warehouse_documents")
}

// Pickovací dávka — skupina položek vychystávaných najednou.
// Typicky e-shop: 20 objednávek za hodinu se zpracuje jako jedna dávka
// a operátor prochází sklad podle optimální trasy.
model Batch {
  id          Int     @id @default(autoincrement())
  number      String  @unique @db.VarChar(50) // např. BAT-2026-0042
  sector      String? @db.VarChar(20) // vyroba, stavba, servis, eshop, pradelna
  status      String  @default("open") @db.VarChar(20) // open, picking, done, cancelled
  assigned_to Int? // operátor (Person), který dávku pickuje
  note        String? @db.Text

  created_at   DateTime  @default(now())
  started_at   DateTime?
  completed_at DateTime?

  assignee Person?     @relation("BatchAssignee", fields: [assigned_to], references: [id])
  items    BatchItem[]

  @@index([status])
  @@index([assigned_to])
  @@index([sector])
  @@map("batches")
}

// Jedna položka pickovací dávky — co, kolik, odkud.
// Seřazeno podle optimální trasy skladem (via sort_order).
model BatchItem {
  id               Int       @id @default(autoincrement())
  batch_id         Int
  material_id      Int
  from_location_id Int? // odkud se má vzít (navrhovaná zdrojová lokace)
  quantity         Decimal   @db.Decimal(12, 3)
  picked_quantity  Decimal?  @db.Decimal(12, 3) // kolik se reálně napickovalo
  status           String    @default("pending") @db.VarChar(20) // pending, picked, short, skipped
  sort_order       Int       @default(0) // pořadí v trase skladem
  picked_by        Int? // Person, kdo položku napickoval
  picked_at        DateTime?
  note             String?   @db.Text

  batch         Batch              @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  material      Material           @relation(fields: [material_id], references: [id])
  from_location WarehouseLocation? @relation(fields: [from_location_id], references: [id])
  picker        Person?            @relation("BatchItemPickedBy", fields: [picked_by], references: [id])

  @@index([batch_id])
  @@index([material_id])
  @@index([status])
  @@map("batch_items")
}

// Tiskárna etiket — centrálně spravovaná, HolyOS backend drží TCP spojení
// a vystavuje tiskové API. Web i PWA volají stejný endpoint.
model Printer {
  id              Int       @id @default(autoincrement())
  name            String    @db.VarChar(100) // např. "Tiskárna Rychnov"
  model           String    @default("TSC_TC200") @db.VarChar(50) // preset: TSC_TC200, ZEBRA_GK420, CUSTOM
  location_id     Int? // kam patří (autoselekce tiskárny podle místa operace)
  connection_type String    @default("lan") @db.VarChar(10) // lan, usb
  ip_address      String?   @db.Inet
  port            Int?
  language        String    @default("ZPL") @db.VarChar(10) // ZPL, TSPL, EPL
  label_width_mm  Decimal   @default(60) @db.Decimal(6, 2)
  label_height_mm Decimal   @default(20) @db.Decimal(6, 2)
  dpi             Int       @default(203)
  priority        Int       @default(0) // autoselekce při více tiskárnách
  is_active       Boolean   @default(true)
  last_ping_ok    DateTime?
  encoding        String    @default("UTF-8") @db.VarChar(20)
  // Pokročilá nastavení (většinou default, skrytá v UI)
  pre_command     String?   @db.Text
  post_command    String?   @db.Text
  gap_mm          Decimal?  @db.Decimal(4, 2)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  location   WarehouseLocation? @relation(fields: [location_id], references: [id])
  print_jobs PrintJob[]

  @@index([location_id])
  @@index([is_active])
  @@map("printers")
}

// Šablona etikety — ZPL/TSPL text s placeholdery {{qr_code}}, {{item_name}}, …
// Backend při tisku dosadí data a pošle na tiskárnu.
model LabelTemplate {
  id          Int     @id @default(autoincrement())
  code        String  @unique @db.VarChar(50) // např. item_label, location_label, document_summary
  name        String  @db.VarChar(255)
  language    String  @default("ZPL") @db.VarChar(10) // ZPL, TSPL, EPL
  width_mm    Decimal @default(60) @db.Decimal(6, 2)
  height_mm   Decimal @default(20) @db.Decimal(6, 2)
  body        String  @db.Text // šablona s placeholdery
  description String? @db.Text
  is_active   Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  print_jobs PrintJob[]

  @@map("label_templates")
}

// Záznam o tisku — auditní stopa. Kdo, kdy, co, kam, úspěch/chyba.
model PrintJob {
  id           Int     @id @default(autoincrement())
  template_id  Int?
  printer_id   Int
  data         Json // hodnoty pro placeholdery šablony
  copies       Int     @default(1)
  status       String  @default("queued") @db.VarChar(20) // queued, printing, done, failed
  error        String? @db.Text
  requested_by Int? // Person
  device_id    String? @db.VarChar(100) // z jaké čtečky/PC byl tisk spuštěn

  created_at  DateTime  @default(now())
  finished_at DateTime?

  template  LabelTemplate? @relation(fields: [template_id], references: [id])
  printer   Printer        @relation(fields: [printer_id], references: [id])
  requester Person?        @relation("PrintJobRequestedBy", fields: [requested_by], references: [id])

  @@index([printer_id])
  @@index([status])
  @@index([created_at])
  @@map("print_jobs")
}

// SKLAD 2.0 — Sériová čísla (servis + trackované kusy)
// Jedno vydané číslo per konkrétní fyzický kus materiálu. Řízení: při příjmu
// materiálu s Material.save_sn_first_scan=true UI vyžádá sken N S/N; při
// výdeji/servisu se S/N mění status + naváže se na zakázku. `sn_mask` na
// Material může obsahovat regex pro validaci formátu S/N.
model SerialNumber {
  id            Int    @id @default(autoincrement())
  material_id   Int
  serial_number String @db.VarChar(100)
  status        String @default("in_stock") @db.VarChar(20) // in_stock, issued, scrapped, returned
  location_id   Int?

  // Audit: kdy se číslo objevilo / vydalo / vyřadilo + vazba na pohyby.
  received_at      DateTime?
  received_move_id Int?
  issued_at        DateTime?
  issued_move_id   Int?
  scrapped_at      DateTime?
  returned_at      DateTime?

  // Vazba na zakázku / servisní případ / dávku.
  reference_type String? @db.VarChar(50) // order, service_case, batch, manual, project
  reference_id   Int?

  received_by Int? // Person — kdo přijal
  issued_by   Int? // Person — kdo vydal
  note        String? @db.Text

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  material        Material           @relation(fields: [material_id], references: [id], onDelete: Cascade)
  location        WarehouseLocation? @relation(fields: [location_id], references: [id])
  received_move   InventoryMovement? @relation("SerialReceivedMove", fields: [received_move_id], references: [id])
  issued_move     InventoryMovement? @relation("SerialIssuedMove", fields: [issued_move_id], references: [id])
  received_person Person?            @relation("SerialReceivedBy", fields: [received_by], references: [id])
  issued_person   Person?            @relation("SerialIssuedBy", fields: [issued_by], references: [id])

  @@unique([material_id, serial_number]) // stejný S/N může teoreticky existovat u různých materiálů
  @@index([material_id])
  @@index([serial_number])
  @@index([status])
  @@index([location_id])
  @@index([reference_type, reference_id])
  @@map("serial_numbers")
}

// =============================================================================
// ÚČETNÍ DOKLADY — FAKTURY, PLATBY, BANKA, POKLADNA, OCR-EMAIL
// Modul "Účetní doklady" (ucetni-doklady). Faktury přijaté i vydané,
// 3-way match (objednávka + příjemka + faktura), workflow schvalování,
// hromadný ABO platební příkaz, výpisy z banky + párování, pokladna,
// upomínky, odevzdání účetní firmě, OCR e-mail ingest.
// =============================================================================

// Faktura (přijatá i vydaná). Pro přijatou: direction=ap, type=received.
// Pro vydanou: direction=ar, type=issued. Dobropisy: type=credit_note_*.
model Invoice {
  id              Int     @id @default(autoincrement())
  invoice_number  String  @unique @db.VarChar(50) // naše interní číslo; sekvenční řada per typ
  external_number String? @db.VarChar(100) // číslo dokladu od dodavatele (AP) nebo ref od zákazníka (AR)
  type            String  @db.VarChar(30) // received, issued, credit_note_received, credit_note_issued, proforma_received, proforma_issued
  direction       String  @db.VarChar(2) // ap (payable), ar (receivable)

  // Partner (dodavatel pro AP, odběratel pro AR)
  company_id Int
  company    Company @relation("InvoiceCompany", fields: [company_id], references: [id])

  // Vazba na objednávku (pro 3-way match)
  order_id Int?
  order    Order? @relation("InvoiceOrder", fields: [order_id], references: [id])

  // Vazba na skladový doklad (příjemka pro AP / dodací list pro AR)
  warehouse_document_id Int?
  warehouse_document    WarehouseDocument? @relation("InvoiceWarehouseDoc", fields: [warehouse_document_id], references: [id])

  // Finanční sumy
  currency      String  @default("CZK") @db.VarChar(3)
  exchange_rate Decimal @default(1) @db.Decimal(12, 6)
  subtotal      Decimal @default(0) @db.Decimal(14, 2) // bez DPH
  vat_amount    Decimal @default(0) @db.Decimal(14, 2)
  total         Decimal @default(0) @db.Decimal(14, 2) // s DPH
  rounding      Decimal @default(0) @db.Decimal(6, 2)
  paid_amount   Decimal @default(0) @db.Decimal(14, 2)

  // DPH režim
  vat_regime String @default("standard") @db.VarChar(30) // standard, reverse_charge, eu_goods, non_vat_payer

  // Data
  date_issued   DateTime  @db.Date
  date_taxable  DateTime? @db.Date // DUZP
  date_received DateTime? // datum doručení (AP)
  date_due      DateTime  @db.Date

  // Platba
  payment_method       String  @default("bank_transfer") @db.VarChar(20) // bank_transfer, cash, card, barter
  variable_symbol      String? @db.VarChar(20)
  constant_symbol      String? @db.VarChar(10)
  specific_symbol      String? @db.VarChar(20)
  partner_bank_account String? @db.VarChar(50) // kam platit (AP) / náš účet (AR)
  partner_iban         String? @db.VarChar(34)
  partner_bic          String? @db.VarChar(11)

  // Stav (workflow):
  //  AP: draft → awaiting_po_match → po_matched → awaiting_goods_receipt → goods_received
  //      → awaiting_approval → approved → ready_to_pay → payment_queued → paid → archived
  //  AR: draft → issued → sent → reminder_1_sent → reminder_2_sent → reminder_3_sent
  //      → paid → overdue → written_off | cancelled
  status String @default("draft") @db.VarChar(30)

  // Schvalování (AP)
  approved_by_id Int?
  approved_by    Person?   @relation("InvoiceApprover", fields: [approved_by_id], references: [id])
  approved_at    DateTime?

  // Upomínky (AR)
  reminder_1_sent_at DateTime?
  reminder_2_sent_at DateTime?
  reminder_3_sent_at DateTime?

  // Zdroj dokumentu
  source          String?      @db.VarChar(30) // manual, email, api, import_xml, factorify
  email_ingest_id Int?
  email_ingest    EmailIngest? @relation("InvoiceEmailIngest", fields: [email_ingest_id], references: [id])

  // OCR
  ocr_confidence     Decimal? @db.Decimal(4, 3) // 0.000–1.000
  ocr_passes_done    Int      @default(0)
  needs_human_review Boolean  @default(false)

  // Skenovaný originál (PDF/obrázek)
  source_file_path String? @db.VarChar(500)

  // Zdrojový PDF (vygenerovaný pro AR, nebo scan pro AP)
  pdf_file_path String? @db.VarChar(500)

  // Meta
  note          String?  @db.Text
  internal_note String?  @db.Text
  tags          String[] @default([])

  created_by_id      Int?
  created_by         Person? @relation("InvoiceCreator", fields: [created_by_id], references: [id])
  // Vždy vyplněné — User, který fakturu založil (i když nemá propojený Person)
  created_by_user_id Int?
  created_by_user    User?   @relation("InvoiceCreatorUser", fields: [created_by_user_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  items           InvoiceItem[]
  allocations     PaymentAllocation[]
  ocr_extractions OcrExtraction[]          @relation("OcrForInvoice")
  approval_steps  InvoiceApprovalStep[]
  reminders       Reminder[]
  cash_movements  CashMovement[]           @relation("CashMovementInvoice")
  handover_items  AccountantHandoverItem[] @relation("HandoverItemInvoice")

  @@index([type, status])
  @@index([direction, status])
  @@index([company_id])
  @@index([order_id])
  @@index([date_issued])
  @@index([date_due])
  @@index([external_number])
  @@index([variable_symbol])
  @@map("invoices")
}

// Řádek faktury. Cost-center umožňuje kategorizaci (auto/osoba/stroj/projekt).
model InvoiceItem {
  id         Int     @id @default(autoincrement())
  invoice_id Int
  invoice    Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  line_order  Int     @default(0)
  description String  @db.VarChar(500)
  quantity    Decimal @db.Decimal(12, 4)
  unit        String  @default("ks") @db.VarChar(20)
  unit_price  Decimal @db.Decimal(14, 4) // bez DPH

  vat_rate   Decimal @default(21) @db.Decimal(5, 2) // 0, 12, 15, 21 %
  subtotal   Decimal @db.Decimal(14, 2) // bez DPH
  vat_amount Decimal @db.Decimal(14, 2)
  total      Decimal @db.Decimal(14, 2) // s DPH

  // Cost-center kategorizace (auto, osoba, stroj, projekt, oddělení, obecné)
  cost_center_id Int?
  cost_center    CostCenter? @relation("InvoiceItemCostCenter", fields: [cost_center_id], references: [id])

  // Vazba na master data
  material_id Int?
  material    Material? @relation("InvoiceItemMaterial", fields: [material_id], references: [id])
  product_id  Int?
  product     Product?  @relation("InvoiceItemProduct", fields: [product_id], references: [id])

  // Přímé assety (pro rychlou statistiku bez cost-centeru)
  vehicle_id Int?
  vehicle    Vehicle? @relation("InvoiceItemVehicle", fields: [vehicle_id], references: [id])
  person_id  Int?
  person     Person?  @relation("InvoiceItemPerson", fields: [person_id], references: [id])

  // Vazba na položku objednávky (3-way match)
  order_item_id Int?
  order_item    OrderItem? @relation("InvoiceItemOrderItem", fields: [order_item_id], references: [id])

  note String? @db.VarChar(500)

  @@index([invoice_id])
  @@index([cost_center_id])
  @@index([vehicle_id])
  @@index([person_id])
  @@index([material_id])
  @@map("invoice_items")
}

// Schvalovací krok u faktury (multi-step approval).
model InvoiceApprovalStep {
  id          Int       @id @default(autoincrement())
  invoice_id  Int
  invoice     Invoice   @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  step_order  Int
  approver_id Int
  approver    Person    @relation("InvoiceApprovalStepApprover", fields: [approver_id], references: [id])
  status      String    @default("pending") @db.VarChar(20) // pending, approved, rejected, skipped
  required    Boolean   @default(true)
  decided_at  DateTime?
  note        String?   @db.Text

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([invoice_id])
  @@index([approver_id, status])
  @@map("invoice_approval_steps")
}

// =============================================================================
// COST CENTERS (nákladová střediska)
// =============================================================================

model CostCenter {
  id   Int    @id @default(autoincrement())
  code String @unique @db.VarChar(50)
  name String @db.VarChar(255)
  // vehicle, person, machine, project, department, general
  type String @db.VarChar(30)

  parent_id Int?
  parent    CostCenter?  @relation("CostCenterHierarchy", fields: [parent_id], references: [id])
  children  CostCenter[] @relation("CostCenterHierarchy")

  // Volitelné navázání na konkrétní entitu (auto, osobu, oddělení)
  vehicle_id    Int?
  vehicle       Vehicle?    @relation("CostCenterVehicle", fields: [vehicle_id], references: [id])
  person_id     Int?
  person        Person?     @relation("CostCenterPerson", fields: [person_id], references: [id])
  department_id Int?
  department    Department? @relation("CostCenterDepartment", fields: [department_id], references: [id])

  active Boolean @default(true)
  note   String? @db.Text

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  invoice_items  InvoiceItem[]  @relation("InvoiceItemCostCenter")
  cash_movements CashMovement[] @relation("CashMovementCostCenter")

  @@index([type, active])
  @@index([vehicle_id])
  @@index([person_id])
  @@map("cost_centers")
}

// =============================================================================
// PLATBY — DÁVKA (ABO BATCH) & JEDNOTLIVÁ PLATBA & ALOKACE
// =============================================================================

// Hromadný platební příkaz do banky (ABO/SEPA/API).
model PaymentBatch {
  id              Int         @id @default(autoincrement())
  batch_number    String      @unique @db.VarChar(50) // PB-2026-0001
  bank_account_id Int
  bank_account    BankAccount @relation(fields: [bank_account_id], references: [id])
  // ABO-KPC, ABO-GPC (pro příkaz), SEPA-XML, MULTICASH, FIO-API, CSOB-API
  format          String      @db.VarChar(30)
  // draft, generated, submitted_to_bank, processed, rejected, cancelled
  status          String      @default("draft") @db.VarChar(30)
  total_count     Int         @default(0)
  total_amount    Decimal     @default(0) @db.Decimal(16, 2)
  file_path       String?     @db.VarChar(500)
  generated_at    DateTime?
  submitted_at    DateTime?
  processed_at    DateTime?
  due_date        DateTime    @db.Date
  note            String?     @db.Text

  created_by_id Int?
  created_by    Person? @relation("PaymentBatchCreator", fields: [created_by_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  payments Payment[]

  @@index([status, due_date])
  @@index([bank_account_id])
  @@map("payment_batches")
}

// Jednotlivá platba (outgoing z batche / incoming z výpisu / hotovost).
model Payment {
  id        Int    @id @default(autoincrement())
  direction String @db.VarChar(3) // out (AP), in (AR)
  method    String @default("bank_transfer") @db.VarChar(20) // bank_transfer, cash, card, barter

  batch_id         Int?
  batch            PaymentBatch? @relation(fields: [batch_id], references: [id])
  cash_register_id Int?
  cash_register    CashRegister? @relation("PaymentCashRegister", fields: [cash_register_id], references: [id])

  bank_transaction_id Int?             @unique
  bank_transaction    BankTransaction? @relation(fields: [bank_transaction_id], references: [id])

  amount     Decimal @db.Decimal(14, 2)
  currency   String  @default("CZK") @db.VarChar(3)
  amount_czk Decimal @db.Decimal(14, 2)

  partner_name    String  @db.VarChar(255)
  partner_account String? @db.VarChar(50)
  variable_symbol String? @db.VarChar(20)
  constant_symbol String? @db.VarChar(10)
  specific_symbol String? @db.VarChar(20)
  message         String? @db.VarChar(140) // zpráva pro příjemce

  scheduled_date DateTime? @db.Date
  executed_date  DateTime? @db.Date

  // draft, queued, submitted, executed, failed, cancelled
  status String @default("draft") @db.VarChar(20)

  allocations PaymentAllocation[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([status, scheduled_date])
  @@index([batch_id])
  @@index([variable_symbol])
  @@map("payments")
}

// Alokace platby na fakturu (m:n — jedna platba může pokrýt více faktur, částečné platby).
model PaymentAllocation {
  id         Int     @id @default(autoincrement())
  payment_id Int
  payment    Payment @relation(fields: [payment_id], references: [id], onDelete: Cascade)
  invoice_id Int
  invoice    Invoice @relation(fields: [invoice_id], references: [id])
  amount     Decimal @db.Decimal(14, 2)
  note       String? @db.VarChar(255)

  created_at DateTime @default(now())

  @@index([payment_id])
  @@index([invoice_id])
  @@map("payment_allocations")
}

// =============================================================================
// BANKA — ÚČTY, VÝPISY, TRANSAKCE, PRAVIDLA PRO PÁROVÁNÍ
// =============================================================================

model BankAccount {
  id                  Int       @id @default(autoincrement())
  name                String    @db.VarChar(100) // "Fio firma", "ČSOB provoz"
  // FIO, CSOB, MONETA, UNICREDIT, KB, RB, OTHER
  bank                String    @db.VarChar(20)
  account_number      String    @db.VarChar(30) // 2501234567
  bank_code           String    @db.VarChar(4) // 2010, 0300, 0600, 2700
  iban                String?   @db.VarChar(34)
  bic                 String?   @db.VarChar(11)
  currency            String    @default("CZK") @db.VarChar(3)
  api_enabled         Boolean   @default(false)
  api_credentials_ref String?   @db.VarChar(255) // klíč do secret store (ENV), ne samotný token
  active              Boolean   @default(true)
  opening_balance     Decimal   @default(0) @db.Decimal(16, 2)
  current_balance     Decimal   @default(0) @db.Decimal(16, 2)
  last_statement_date DateTime? @db.Date
  note                String?   @db.Text

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  statements      BankStatement[]
  transactions    BankTransaction[]
  payment_batches PaymentBatch[]

  @@unique([account_number, bank_code])
  @@index([bank, active])
  @@map("bank_accounts")
}

model BankStatement {
  id               Int         @id @default(autoincrement())
  bank_account_id  Int
  bank_account     BankAccount @relation(fields: [bank_account_id], references: [id])
  statement_number String      @db.VarChar(50)
  period_from      DateTime    @db.Date
  period_to        DateTime    @db.Date
  opening_balance  Decimal     @db.Decimal(16, 2)
  closing_balance  Decimal     @db.Decimal(16, 2)
  // api, gpc_upload, csv_upload, mt940_upload
  source           String      @db.VarChar(30)
  file_path        String?     @db.VarChar(500)
  imported_at      DateTime    @default(now())
  imported_by_id   Int?

  transactions BankTransaction[]

  @@unique([bank_account_id, statement_number])
  @@index([period_from, period_to])
  @@map("bank_statements")
}

model BankTransaction {
  id              Int            @id @default(autoincrement())
  bank_account_id Int
  bank_account    BankAccount    @relation(fields: [bank_account_id], references: [id])
  statement_id    Int?
  statement       BankStatement? @relation(fields: [statement_id], references: [id])

  transaction_date DateTime  @db.Date
  value_date       DateTime? @db.Date
  direction        String    @db.VarChar(3) // in, out
  amount           Decimal   @db.Decimal(14, 2)
  currency         String    @default("CZK") @db.VarChar(3)

  counterparty_name    String? @db.VarChar(255)
  counterparty_account String? @db.VarChar(50)
  variable_symbol      String? @db.VarChar(20)
  constant_symbol      String? @db.VarChar(10)
  specific_symbol      String? @db.VarChar(20)
  message              String? @db.VarChar(255)
  reference            String? @db.VarChar(100) // reference banky (unikátní ID transakce)

  // unmatched, matched, ignored, needs_review
  match_status  String        @default("unmatched") @db.VarChar(20)
  // vs, amount_partner, manual, rule
  match_method  String?       @db.VarChar(20)
  match_rule_id Int?
  match_rule    MatchingRule? @relation(fields: [match_rule_id], references: [id])

  // Jedna transakce = 0 nebo 1 Payment (1:1)
  payment Payment?

  note           String?   @db.Text
  resolved_by_id Int?
  resolved_at    DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([bank_account_id, reference])
  @@index([transaction_date])
  @@index([match_status])
  @@index([variable_symbol])
  @@index([counterparty_account])
  @@map("bank_transactions")
}

// Pravidlo pro automatické párování opakovaných plateb (nájem, pojistky, trvalé příkazy).
model MatchingRule {
  id       Int     @id @default(autoincrement())
  name     String  @db.VarChar(255)
  priority Int     @default(100)
  active   Boolean @default(true)

  // Kritéria
  direction                  String?  @db.VarChar(3) // in, out
  counterparty_account       String?  @db.VarChar(50)
  counterparty_name_contains String?  @db.VarChar(255)
  variable_symbol            String?  @db.VarChar(20)
  amount_min                 Decimal? @db.Decimal(14, 2)
  amount_max                 Decimal? @db.Decimal(14, 2)

  // Akce
  // ignore, auto_match_invoice, auto_match_cost_center, notify
  action         String @db.VarChar(30)
  cost_center_id Int?
  assignee_id    Int?

  transactions BankTransaction[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([active, priority])
  @@map("matching_rules")
}

// =============================================================================
// POKLADNA
// =============================================================================

model CashRegister {
  id                 Int       @id @default(autoincrement())
  name               String    @db.VarChar(100)
  currency           String    @default("CZK") @db.VarChar(3)
  location           String?   @db.VarChar(255)
  responsible_id     Int?
  responsible        Person?   @relation("CashRegisterResponsible", fields: [responsible_id], references: [id])
  opening_balance    Decimal   @default(0) @db.Decimal(12, 2)
  current_balance    Decimal   @default(0) @db.Decimal(12, 2)
  last_reconciled_at DateTime?
  active             Boolean   @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  movements CashMovement[]
  payments  Payment[]      @relation("PaymentCashRegister")

  @@index([active])
  @@map("cash_registers")
}

model CashMovement {
  id               Int          @id @default(autoincrement())
  cash_register_id Int
  cash_register    CashRegister @relation(fields: [cash_register_id], references: [id])
  date             DateTime     @db.Date
  document_number  String       @unique @db.VarChar(30) // P2026000123 / V2026000123
  direction        String       @db.VarChar(3) // in, out
  amount           Decimal      @db.Decimal(12, 2)
  // invoice_payment, fuel, salary_advance, petty_cash_top_up, sale, refund, other
  purpose          String       @db.VarChar(50)
  description      String       @db.VarChar(500)

  // Volitelné vazby
  invoice_id     Int?
  invoice        Invoice?    @relation("CashMovementInvoice", fields: [invoice_id], references: [id])
  cost_center_id Int?
  cost_center    CostCenter? @relation("CashMovementCostCenter", fields: [cost_center_id], references: [id])

  receipt_file_path String? @db.VarChar(500) // naskenovaný paragon

  created_by_id Int?
  created_by    Person? @relation("CashMovementCreator", fields: [created_by_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([cash_register_id, date])
  @@index([invoice_id])
  @@map("cash_movements")
}

// =============================================================================
// E-MAIL INGEST + OCR
// =============================================================================

// Přijatý e-mail s potenciální fakturou (mailbox faktury@bestseries.cz).
model EmailIngest {
  id          Int      @id @default(autoincrement())
  mailbox     String   @db.VarChar(255)
  message_id  String   @unique @db.VarChar(255) // RFC 5322 Message-ID
  thread_id   String?  @db.VarChar(255)
  from_email  String   @db.VarChar(255)
  from_name   String?  @db.VarChar(255)
  to_email    String   @db.VarChar(255)
  subject     String   @db.VarChar(500)
  body_text   String?  @db.Text
  body_html   String?  @db.Text
  received_at DateTime
  fetched_at  DateTime @default(now())

  // received → parsing → extracting → awaiting_review
  //         → linked_to_invoice | unreadable | spam | duplicate | processed
  status String @default("received") @db.VarChar(30)

  confidence Decimal? @db.Decimal(4, 3)
  attempts   Int      @default(0)

  // Upozornění odesílateli (nečitelný doklad)
  sender_notified_at   DateTime?
  sender_notify_reason String?   @db.VarChar(255)

  note String? @db.Text

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  attachments EmailAttachment[]
  invoices    Invoice[]         @relation("InvoiceEmailIngest")
  extractions OcrExtraction[]   @relation("OcrForEmailIngest")

  @@index([status, received_at])
  @@index([mailbox])
  @@map("email_ingests")
}

model EmailAttachment {
  id                   Int         @id @default(autoincrement())
  email_ingest_id      Int
  email_ingest         EmailIngest @relation(fields: [email_ingest_id], references: [id], onDelete: Cascade)
  filename             String      @db.VarChar(500)
  content_type         String      @db.VarChar(100)
  size_bytes           Int
  file_path            String      @db.VarChar(500)
  source               String      @default("attachment") @db.VarChar(20) // attachment, link_download
  source_url           String?     @db.VarChar(1000)
  sha256               String?     @db.VarChar(64)
  is_invoice_candidate Boolean     @default(false)

  created_at DateTime @default(now())

  extractions OcrExtraction[] @relation("OcrForAttachment")

  @@index([email_ingest_id])
  @@index([sha256])
  @@map("email_attachments")
}

// Jeden pass extrakce (multi-pass pipeline pro vysokou jistotu).
model OcrExtraction {
  id              Int              @id @default(autoincrement())
  email_ingest_id Int?
  email_ingest    EmailIngest?     @relation("OcrForEmailIngest", fields: [email_ingest_id], references: [id])
  attachment_id   Int?
  attachment      EmailAttachment? @relation("OcrForAttachment", fields: [attachment_id], references: [id])
  invoice_id      Int?
  invoice         Invoice?         @relation("OcrForInvoice", fields: [invoice_id], references: [id])

  pass_number Int
  // claude_vision_header, claude_vision_lines, ares_lookup, vies_lookup,
  // vat_math_check, duplicate_check, link_follow
  pass_type   String  @db.VarChar(50)
  model_used  String? @db.VarChar(50) // claude-sonnet-4-6, claude-opus-4-6
  extracted_data Json
  confidence  Decimal @db.Decimal(4, 3)
  warnings    Json?
  errors      Json?

  input_tokens  Int?
  output_tokens Int?
  cost_czk      Decimal? @db.Decimal(8, 4)

  executed_at DateTime @default(now())
  duration_ms Int?

  @@index([email_ingest_id])
  @@index([invoice_id])
  @@index([pass_type])
  @@map("ocr_extractions")
}

// =============================================================================
// UPOMÍNKY (Fáze 7)
// =============================================================================

model Reminder {
  id            Int       @id @default(autoincrement())
  invoice_id    Int
  invoice       Invoice   @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  level         Int // 1, 2, 3
  scheduled_at  DateTime
  sent_at       DateTime?
  sent_to_email String?   @db.VarChar(255)
  subject       String    @db.VarChar(255)
  body          String    @db.Text
  // scheduled, sent, bounced, cancelled
  status        String    @default("scheduled") @db.VarChar(20)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([invoice_id, level])
  @@index([status, scheduled_at])
  @@map("reminders")
}

// =============================================================================
// ODEVZDÁNÍ ÚČETNÍ FIRMĚ (Fáze 10) — měsíční ZIP balíček
// =============================================================================

model AccountantHandover {
  id             Int    @id @default(autoincrement())
  period_month   Int // 1–12
  period_year    Int
  // preparing → ready → sent → confirmed_by_accountant → closed
  status         String @default("preparing") @db.VarChar(30)

  document_count Int     @default(0)
  total_received Decimal @default(0) @db.Decimal(14, 2)
  total_issued   Decimal @default(0) @db.Decimal(14, 2)
  total_cash     Decimal @default(0) @db.Decimal(14, 2)

  zip_file_path String? @db.VarChar(500)
  checklist     Json // [{ item, done: bool, note }]

  sent_at       DateTime?
  sent_to_email String?   @db.VarChar(255)
  confirmed_at  DateTime?
  note          String?   @db.Text

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  items AccountantHandoverItem[]

  @@unique([period_year, period_month])
  @@index([status])
  @@map("accountant_handovers")
}

model AccountantHandoverItem {
  id          Int                @id @default(autoincrement())
  handover_id Int
  handover    AccountantHandover @relation(fields: [handover_id], references: [id], onDelete: Cascade)
  // invoice_received | invoice_issued | cash_movement_summary | bank_statement | other
  document_type String           @db.VarChar(30)
  document_id   Int

  // Volitelná silná vazba na Invoice (pro AP/AR)
  invoice_id Int?
  invoice    Invoice? @relation("HandoverItemInvoice", fields: [invoice_id], references: [id])

  file_path String? @db.VarChar(500)
  included  Boolean @default(true)
  note      String? @db.VarChar(500)

  created_at DateTime @default(now())

  @@index([handover_id])
  @@index([document_type, document_id])
  @@map("accountant_handover_items")
}

// =============================================================================
// APLIKAČNÍ NASTAVENÍ (key/value)
// =============================================================================
// Universální key/value úložiště pro user-configurable parametry, které:
//  - nejsou per-uživatel (pro to máme User.preferences),
//  - nejsou tajné/secret (pro to máme .env / secret store),
//  - mohou se měnit za běhu bez nasazení (např. limity, prahy, default volby).
//
// Klíče používáme dot-notation per modul (např. "accounting.payment_batch.approval_limit_czk").
// Hodnota je string — typování v aplikaci přes services/settings.js helper.

model AppSetting {
  id          Int      @id @default(autoincrement())
  key         String   @unique @db.VarChar(120)
  value       String   @db.Text
  value_type  String   @default("string") @db.VarChar(20) // string, number, boolean, json
  description String?  @db.Text
  scope       String?  @db.VarChar(50)

  updated_by_user_id Int?
  updated_by         User? @relation("AppSettingUpdater", fields: [updated_by_user_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([scope])
  @@map("app_settings")
}
