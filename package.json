{
  "name": "holyos",
  "version": "0.4.0",
  "description": "HolyOS — AI-powered výrobní systém (Best Series)",
  "main": "app.js",
  "scripts": {
    "dev": "node --watch app.js",
    "start": "npx prisma migrate deploy && node app.js",
    "start:legacy": "node server.js",
    "build": "npx prisma generate && npm --prefix clients/pwa-sklad ci && npm --prefix clients/pwa-sklad run build",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:seed": "node scripts/migrate-json-to-postgres.js",
    "db:studio": "npx prisma studio",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "private": true,
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@prisma/client": "^6.19.3",
    "@prisma/engines": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.5",
    "prisma": "^6.19.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.9.3"
  }
}
