{
  "name": "vyroba",
  "version": "0.2.0",
  "description": "HOLYOS — Řízení výroby (Best Series)",
  "main": "server.js",
  "scripts": {
    "dev": "tsc -b && node --watch server.js",
    "build": "tsc -b",
