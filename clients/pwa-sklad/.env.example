# HolyOS PWA sklad — environment template
# Zkopíruj do `.env.local` a uprav dle prostředí.

# URL HolyOS backendu, kam dev server proxuje /api volání.
# Pro produkční testy lze mířit přímo na Railway.
VITE_API_PROXY=http://localhost:3000

# Pokud PWA běží na jiném originu než backend (typický produkční scénář
# na SUNMI čtečce), nastav plnou absolutní URL. Když je prázdné, apiClient
# volá relativní /api (funguje jen když PWA hostuje stejný backend).
VITE_API_BASE_URL=
